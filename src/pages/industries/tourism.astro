---
import BaseLayout from '@layouts/BaseLayout.astro';
import HeroLeaf from '@components/hero/HeroLeaf.astro';
import Toc from '@components/ui/Toc.astro';
import StickyMobileCta from '@components/ui/StickyMobileCta.astro';
import CtaSection from '@components/sections/CtaSection.astro';
import CasesGrid from '@components/sections/CasesGrid.astro';
import Faq from '@components/sections/Faq.astro';
import Label from '@components/ui/Label.astro';

import QuickAnswer from '@components/seo/QuickAnswer.astro';
import LastUpdated from '@components/seo/LastUpdated.astro';
const title = 'Реклама для туризма - турагентства, санатории, экскурсии - WEBNOSTRA PERFORMANCE';
const description =
  'Performance-маркетинг для турагентств, санаториев, экскурсионных компаний, отелей и сервисов бронирования. 15,000+ заявок в нише, средний ROI 450%, CPL от $4.19. Работаем с сезонностью, мультиязычной аудиторией, оптимизацией на квалифицированные заявки.';
const canonical = 'https://webnostra.pro/industries/tourism/';

const breadcrumbs = [
  { name: 'Главная', url: '/' },
  { name: 'Отрасли', url: '/industries/' },
  { name: 'Туризм', url: '/industries/tourism/' },
];

const toc = [
  { id: 'dlya-kogo', label: 'Для кого работаем' },
  { id: 'specifika', label: 'Специфика туризма' },
  { id: 'sezon', label: 'Работа с сезонностью' },
  { id: 'kanaly', label: 'Каналы рекламы' },
  { id: 'keysy', label: 'Кейсы с цифрами' },
  { id: 'process', label: 'Процесс запуска' },
  { id: 'faq', label: 'Вопросы и ответы' },
  { id: 'form-final', label: 'Обсудить проект' },
];
---

<BaseLayout title={title} description={description} canonicalPath="/industries/tourism/">
  <HeroLeaf
    label="Отрасль · Туризм"
    title='Реклама туризма, которая работает <span class="accent">в пик сезона и в межсезонье</span>'
    description="Ведем платный трафик для турагентств, санаториев, экскурсионных компаний, отелей, яхт-клубов и сервисов бронирования. 15,000+ заявок в нише, средний ROI 450%, средний CPL по турпроектам $4.19. Работаем глобально - от Пхукета до Кавминвод. Понимаем сезонность, мультиязычность, работу с горячей аудиторией в короткое окно бронирования."
    ctaText="Обсудить проект"
    ctaHref="#form-final"
    breadcrumbs={breadcrumbs}
  />

  <LastUpdated date="22 апреля 2026" version="v1.0" author={{ name: "Магош Альшанский", url: "/authors/magosh/" }} />

  <QuickAnswer
    title="Реклама для туризма и санаториев"
    summary="15,000+ заявок для турагентств, санаториев, экскурсионных компаний и сервисов бронирования. Работаем с сезонностью, знаем как работать с разными языковыми группами."
    items={[
      { label: "Средний CPL", value: "$4.19 (экскурсии Пхукет), $5 (KZ турагентство), 492 руб (санатории КМВ), 500 руб (южный тур)" },
      { label: "Максимальный ROI", value: "520% (KMV Sanatoria)" },
      { label: "Ключевые каналы", value: "Meta Ads (международный туризм), Яндекс Директ (санатории РФ), Google Ads (Европа)" },
      { label: "Специфика", value: "Сильная сезонность - запускаем кампании за 2 месяца до пика спроса" },
      { label: "Форматы", value: "Квизы с подбором тура/санатория, персональные предложения, ретаргетинг с FOMO" },
      { label: "Минимальный бюджет", value: "$2,500 в месяц" },
      { label: "Срок запуска", value: "48 часов - не пропускаем сезон" },
    ]}
  />

  <Toc items={toc} />

  <section id="dlya-kogo" class="section">
    <div class="container narrow">
      <Label text="Для кого" />
      <h2>С какими проектами мы работаем в туризме</h2>
      <p>
        Туризм - отрасль с большим разбросом по бизнес-моделям. Продать экскурсию
        за $30 и путевку в санаторий за 85,000 рублей - две разные работы,
        разные воронки, разные каналы. Мы работаем с пятью основными типами
        туристических проектов.
      </p>

      <div class="grid cols-2">
        <div class="card">
          <h3>Турагентства и туроператоры</h3>
          <p>
            Классические агентства по продаже пакетных туров и авторских
            маршрутов. Основная конкуренция - с агрегаторами типа Travelata и
            прямым бронированием через Booking. Работаем через отстройку:
            эксклюзивные пакеты, доп-услуги, личный менеджер. Турагентство в
            Казахстане - 370 заявок по $5, 89 продаж при бюджете $1,850.
          </p>
        </div>

        <div class="card">
          <h3>Санатории и wellness-туризм</h3>
          <p>
            Отдельная большая ниша с длинным циклом принятия решения и
            возрастной аудиторией 50+. Сегментация по медицинским показаниям,
            работа с возражениями через отзывы. Санаторий им. Пирогова в Одессе -
            1,241 заявка, 16% конверсия. Сервис бронирования путевок в КМВ -
            5,926 броней, ROI кампании 520%.
          </p>
        </div>

        <div class="card">
          <h3>Экскурсионные компании</h3>
          <p>
            Продажа впечатлений за 2-5 дней до события. Короткое окно
            принятия решения, FOMO-креативы, сезонность. Экскурсионная компания
            на Пхукете - 2,761 лид за $11,563, окупаемость на 3-й день.
            Ретаргетинг на тех, кто искал развлечения, FOMO-креативы вроде
            «осталось 3 места на завтра».
          </p>
        </div>

        <div class="card">
          <h3>Премиум: яхты, VIP-экскурсии, private tours</h3>
          <p>
            Высокий чек ($500-5,000+), узкая аудитория. Таргетируемся на тех,
            кто бронирует отели 5 звезд или имеет соответствующие интересы.
            Работаем не через характеристики продукта, а через эмоции. Аренда
            яхт премиум-класса на Пхукете - ROI 320%, конверсия 15%, средний
            чек $4,200.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section id="specifika" class="section bg-dark">
    <div class="container narrow">
      <Label text="Что особенного" />
      <h2>Чем туризм отличается от других ниш</h2>
      <p>
        Реклама туризма - отдельная дисциплина. Здесь свои правила: резкие пики
        спроса, короткие окна принятия решения, сильное влияние эмоций и FOMO,
        необходимость работать с несколькими языковыми группами одновременно.
      </p>

      <ul class="process-steps">
        <li>
          <strong>Окно принятия решения от 2 дней до 6 месяцев.</strong> Экскурсия
          бронируется за 2-3 дня, пакетный тур за 2-4 недели, путевка в санаторий
          за 1-3 месяца, круиз или большое путешествие за 3-6 месяцев. Под
          каждый тип - своя механика работы с аудиторией и разные метрики
          оценки успеха.
        </li>
        <li>
          <strong>Сезонность определяет экономику.</strong> В пик сезона CPL
          падает в 2-3 раза, потому что все ищут. В межсезонье наоборот -
          аудитория узкая и дорогая, но конкуренция слабее. Мы не пытаемся
          работать одинаково круглый год: в пик - масштабируем, в межсезонье -
          тестируем и разогреваем базу на следующий пик.
        </li>
        <li>
          <strong>FOMO и ограниченность как основной механизм.</strong> Туризм -
          одна из немногих ниш, где искусственные ограничения («осталось 3 места»,
          «цена вырастет завтра», «эксклюзивное предложение до понедельника»)
          реально работают и поднимают конверсию в 1.5-2 раза. Важно использовать
          их честно, а не как маркетинговую манипуляцию.
        </li>
        <li>
          <strong>Мультиязычность.</strong> Клиенты турагентства на Пхукете -
          русские, англоязычные, тайцы, арабы. Каждой группе нужна своя реклама
          с нативным языком и культурным контекстом. Простой перевод с русского
          на английский не работает - у них разные триггеры и разные боли.
        </li>
      </ul>
    </div>
  </section>

  <section id="sezon" class="section">
    <div class="container narrow">
      <Label text="Сезонность" />
      <h2>Как мы работаем с пиками и межсезоньем</h2>
      <p>
        Главная ошибка в рекламе туризма - работать одинаково круглый год. Бюджет
        сливается в низкий сезон на дорогих холодных лидов, а в пик - не успеваем
        разогнаться и упускаем горячий спрос. Правильная модель - трехфазная.
      </p>

      <div class="grid cols-3">
        <div class="card">
          <h3>Разогрев: за 2-3 месяца до пика</h3>
          <p>
            Собираем базу для ретаргетинга через недорогой контентный трафик:
            видео с направлений, гайды по стране, подборки отелей. Тестируем
            креативы и офферы на небольшом бюджете. Параллельно запускаем рекламу
            с офферами «раннее бронирование» и скидками за предоплату.
          </p>
        </div>

        <div class="card">
          <h3>Пик: максимальная активность</h3>
          <p>
            Максимальные бюджеты, масштабируем рабочие связки, без экспериментов.
            Большая часть трафика - на ретаргетинг по собранной весной базе.
            Горячая аудитория конвертируется в 2-3 раза лучше холодной. Пик для
            большинства направлений - 6-12 недель в году, когда выручка делается
            за весь сезон.
          </p>
        </div>

        <div class="card">
          <h3>Межсезонье: переключение продукта</h3>
          <p>
            В низкий сезон - либо оптимизируемся на «раннее бронирование» следующего
            пика (со скидкой 20-30%), либо переключаемся на другой продукт.
            Отельер переходит на MICE и корпоративных клиентов. Санаторий - на
            лечебные программы в будни. Турагентство - на city-break и
            сити-туризм круглогодичных направлений.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section id="kanaly" class="section bg-dark">
    <div class="container narrow">
      <Label text="Каналы" />
      <h2>Какие каналы работают в туризме</h2>
      <p>
        Туризм - это визуальная ниша. Видео с дронов, подборки фотографий,
        отзывы с эмоциями - основной контент, который двигает рекламу. Поэтому
        главные каналы - те, где есть визуальная лента.
      </p>

      <div class="grid cols-2">
        <div class="card">
          <h3><a href="/services/meta-ads/">Meta Ads</a> для международного туризма</h3>
          <p>
            Facebook и Instagram - основа для экскурсий, отелей, яхт, VIP-продуктов
            за пределами РФ. Алгоритм с интересом к путешествиям, look-alike на
            купивших. Работает для Пхукета, Бали, Дубая, европейских направлений.
            Для экскурсий на Пхукете дал 2,761 лид при CPL $4.19.
          </p>
        </div>

        <div class="card">
          <h3><a href="/services/yandex-direct/">Яндекс Директ</a> для РФ-туризма</h3>
          <p>
            В России Яндекс - основной канал для турагентств, санаториев,
            бронирований. Поиск по запросам «путевка в КМВ», «тур в Сочи»,
            «санаторий с бассейном» плюс РСЯ. Для сервиса бронирования путевок
            в КМВ за 6.6M рублей бюджета получили 5,926 броней и ROI 520%.
          </p>
        </div>

        <div class="card">
          <h3><a href="/services/google-ads/">Google Ads</a> для англоязычной аудитории</h3>
          <p>
            Для отелей и турпродуктов, которые работают с иностранными туристами
            в Таиланде, на Бали, в Дубае. Performance Max с фидом номеров и
            туров, поиск по запросам на английском, YouTube-реклама с видео
            направлений. В связке с Meta часто дает лучших покупателей с
            высоким чеком.
          </p>
        </div>

        <div class="card">
          <h3>Офлайн-конверсии обязательны</h3>
          <p>
            В туризме много заявок не конвертируется в бронь - человек передумал,
            выбрал другое направление, отменил. Нужно передавать в кабинет именно
            оплаченные брони, а не заявки. Для санатория Пирогова подключение
            офлайн-конверсий помогло сохранить 70% загрузки в экономический
            кризис.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section id="keysy" class="section">
    <div class="container narrow">
      <Label text="Кейсы" />
      <h2>Три проекта из разных подниш туризма</h2>

      <article class="case-inline">
        <div class="case-head">
          <span class="case-pill">Экскурсии · Пхукет</span>
          <h3>Экскурсионная компания - 2,761 лид, окупаемость на 3-й день</h3>
        </div>

        <p>
          Экскурсионная компания на Пхукете в конце высокого сезона. Задача -
          распродать остатки мест за октябрь-январь. Конкуренция максимальная:
          сотни операторов борются за одного туриста в окне 2-5 дней до
          экскурсии.
        </p>

        <p>
          Построили рекламу на FOMO и ретаргетинге: основной трафик вели на
          тех, кто искал развлечения на Пхукете в последние 30 дней. Креативы -
          дрон-съемка маршрутов, живые видео с туристами на яхтах и у
          водопадов. Оффер менялся по дням: «Осталось 3 места на завтра»,
          «Скидка 20% только в день заявки». Средний чек вырос с $80 до $120
          за счет апселла дополнительных опций.
        </p>

        <div class="case-numbers">
          <div><span>$11,563</span><em>бюджет</em></div>
          <div><span>2,761</span><em>лид</em></div>
          <div><span>$4.19</span><em>CPL</em></div>
          <div><span>21.8%</span><em>CR в лид</em></div>
        </div>

        <a class="case-link" href="/portfolio/phuket-excursions/">Полный кейс Phuket Excursions →</a>
      </article>

      <article class="case-inline">
        <div class="case-head">
          <span class="case-pill">Санаторий · Кавминводы · РФ</span>
          <h3>Путевки в санатории КМВ - 1,038 заявок и ROI 520%</h3>
        </div>

        <p>
          Агентство по продаже путевок в санатории Кавказских Минеральных Вод.
          Огромная конкуренция: санатории часто напрямую продают путевки, плюс
          есть агрегаторы. Задача - привлечь людей с конкретными медицинскими
          запросами, которым нужно профильное лечение.
        </p>

        <p>
          Создали квиз для подбора санатория по медицинским показаниям -
          17 вопросов, на выходе человек получал 3 санатория с обоснованием.
          Разработали семантическое ядро по узким запросам: «восстановление
          после COVID», «программа для диабетиков», «лечение опорно-двигательной
          системы». Настроили передачу офлайн-конверсий из CRM агентства для
          оптимизации на оплаченные брони. Квиз увеличил конверсию сайта в
          2.5 раза.
        </p>

        <div class="case-numbers">
          <div><span>510,820 ₽</span><em>бюджет</em></div>
          <div><span>1,038</span><em>заявок</em></div>
          <div><span>492 ₽</span><em>CPL</em></div>
          <div><span>520%</span><em>ROI</em></div>
        </div>

        <a class="case-link" href="/portfolio/kmv-sanatoria/">Полный кейс КМВ →</a>
      </article>

      <article class="case-inline">
        <div class="case-head">
          <span class="case-pill">Турагентство · Казахстан</span>
          <h3>Турагентство Казахстан - квалифицированные заявки по $5</h3>
        </div>

        <p>
          Турагентство, работающее с казахстанским рынком. Основная проблема -
          казахстанцы привыкли бронировать туры напрямую через агрегаторы.
          Задача агентства - дать что-то, чего нет в массовых сервисах.
        </p>

        <p>
          Построили позиционирование на эксклюзивных пакетах с доп-услугами:
          визовая поддержка, рассрочка 0%, страховка от отмены, личный менеджер
          24/7. Креативы в Meta с реальными фото клиентов из поездок и
          отзывами. Передавали в Meta CRM-статусы: лид прошел квалификацию,
          оплатил тур. За 6 месяцев при бюджете $1,850 получили 370 заявок по
          $5, 89 продаж.
        </p>

        <div class="case-numbers">
          <div><span>$1,850</span><em>бюджет</em></div>
          <div><span>370</span><em>заявок</em></div>
          <div><span>$5</span><em>CPL</em></div>
          <div><span>89</span><em>продаж</em></div>
        </div>
      </article>

      <p class="muted">
        В туристическом портфеле еще: яхтенная компания на Пхукете (ROI 320%,
        средний чек $4,200), сервис бронирования путевок в КМВ (5,926 броней,
        6.6M рублей бюджета), санаторий им. Пирогова в Одессе (1,241 заявка,
        сохранение 70% загрузки в кризис), турагентство на юге России (500
        рублей за заявку, ROI 450%).
      </p>
    </div>
  </section>

  <CasesGrid
    label="Все кейсы"
    title="Кейсы в туризме"
    subtitle="Проекты от экскурсий до санаториев, от Пхукета до Кавминвод."
    industry="tourism"
    limit={9}
  />

  <section id="process" class="section bg-dark">
    <div class="container narrow">
      <Label text="Процесс" />
      <h2>Как мы стартуем работу с турпроектом</h2>
      <ul class="process-steps">
        <li>
          <strong>Изучение сезонности.</strong> В первую встречу смотрим на
          календарь загрузки клиента за 2-3 последних года. Понимаем, где пики,
          где провалы, где можно работать на раннее бронирование. Под это
          выстраиваем медиаплан и бюджет по месяцам.
        </li>
        <li>
          <strong>Аудит воронки и инструментов.</strong> Проверяем сайт или
          лендинг, квиз (если есть), CRM, систему бронирования. В туризме
          важна скорость ответа менеджера - если человек ждет больше часа,
          он уже уехал на агрегатор. Настраиваем интеграции для мгновенного
          уведомления.
        </li>
        <li>
          <strong>Запуск под ближайший пик.</strong> Если до пика 2-3 месяца -
          начинаем сбор базы и прогрев. Если меньше месяца - сразу масштабируем
          рабочие связки. Если межсезонье - начинаем с раннего бронирования
          и тестирования связок на маленьком бюджете.
        </li>
        <li>
