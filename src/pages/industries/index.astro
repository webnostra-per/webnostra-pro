---
import BaseLayout from '@layouts/BaseLayout.astro';
import HeroHub from '@components/hero/HeroHub.astro';
import CtaSection from '@components/sections/CtaSection.astro';
import Faq from '@components/sections/Faq.astro';
import Label from '@components/ui/Label.astro';
import StickyMobileCta from '@components/ui/StickyMobileCta.astro';
import QuickAnswer from '@components/seo/QuickAnswer.astro';
import LastUpdated from '@components/seo/LastUpdated.astro';
import { getCollection } from 'astro:content';

const title = 'Отрасли - по каким нишам работает WEBNOSTRA PERFORMANCE';
const description =
  'Профильные команды под 6 направлений: недвижимость, e-commerce, инфобизнес, туризм, медицина, B2B. 200+ проектов, $3M+ бюджетов, 50+ ниш в портфеле. За каждой отраслью - своя команда со специфичным подходом и кейсами.';
const canonical = 'https://webnostra.pro/industries/';

const breadcrumbs = [
  { name: 'Главная', url: '/' },
  { name: 'Отрасли', url: '/industries/' },
];

const heroMeta = [
  { value: '6', label: 'отраслевых направлений' },
  { value: '50+', label: 'ниш в портфеле' },
  { value: '200+', label: 'проектов' },
];

const industries = (await getCollection('industries'))
  .map(i => i.data)
  .sort((a, b) => a.order - b.order);
---

<BaseLayout title={title} description={description} canonicalPath="/industries/">
  <HeroHub
    label="Отрасли"
    title="Шесть направлений, где у нас собрана отраслевая команда и глубина кейсов"
    description="WEBNOSTRA PERFORMANCE не универсальное агентство. Мы специализируемся на шести направлениях, в каждом из которых за 8 лет накопили минимум 15-20 проектов, отработали типовые воронки и поняли, что реально двигает экономику в этой нише. Эта страница - быстрая навигация: выбираете свою отрасль и переходите на подробный разбор со всеми кейсами, каналами и подходом."
    meta={heroMeta}
    breadcrumbs={breadcrumbs}
  />

  <LastUpdated date="22 апреля 2026" version="v1.0" author={{ name: "Магош Альшанский", url: "/authors/magosh/" }} />

  <QuickAnswer
    title="6 отраслей экспертизы WEBNOSTRA PERFORMANCE"
    summary="Не универсальное агентство, а 6 профильных команд под конкретные ниши. В каждой 15-20+ проектов, отработанные воронки и понимание, что реально двигает экономику в этой отрасли. Лучше 1 команда под недвижимость, чем 1 таргетолог на 10 индустрий."
    items={[
      { label: "Недвижимость", value: "Флагман, 9 кейсов. $3.2M pipeline (Premium Villas Phuket), 12 сделок в Дубае, 20 продаж загородных домов/мес" },
      { label: "E-commerce", value: "48,000+ заказов в портфеле. LUDING - 36,500 заказов, 210М руб выручки за 2.5 года" },
      { label: "EdTech и онлайн-школы", value: "15,000+ лидов. Beyond Taylor 80 продаж на 12.5М руб, Алгоритмика $3/лид" },
      { label: "Туризм и санатории", value: "15,000+ заявок. От $4.19/лид (экскурсии Пхукет) до 492 руб (санатории КМВ)" },
      { label: "Медицина", value: "7 кейсов в стоматологии по 5 странам. ROI 760% за 28 дней (Прага)" },
      { label: "B2B и услуги", value: "Юристы, маркировка, упаковка для маркетплейсов, ТСЖ - длинный цикл, чеки 45K-500K руб" },
    ]}
  />

  <section id="logic" class="section">
    <div class="container narrow">
      <Label text="Как это устроено" />
      <h2>Почему у нас команды под нишу, а не универсальный отдел трафика</h2>
      <p>
        За первые 3-4 года работы мы попробовали обе модели. Универсальный отдел,
        который ведет все подряд - от стоматологии до застройщика - быстро упирается
        в потолок: таргетолог не успевает следить за нюансами каждого рынка,
        переключается между кабинетами с разной механикой, не накапливает экспертизу
        ни в одной нише. Клиенты чувствуют это через 2-3 месяца: цифры стабилизируются,
        но не растут.
      </p>

      <p>
        Сейчас у нас шесть отраслевых направлений с закрепленными лид-специалистами.
        Каждая команда знает не только Meta Ads или Директ, но и специфику продукта:
        как устроена сделка у застройщика на Пхукете, какой CR в оплату на пробный
        урок считается нормой в онлайн-школе английского, как работать с клиникой
        в рамках 38-ФЗ, где в e-com точка безубыточности по ROAS. Благодаря этому
        мы не тратим первые 1-2 месяца работы с новым клиентом на изучение ниши -
        стартуем с уже понятными гипотезами.
      </p>

      <div class="grid cols-3">
        <div class="card">
          <h3>За каждой нишей - лид-специалист</h3>
          <p>
            Недвижимость ведет Дмитрий Добжанский, 4 года в real-estate маркетинге,
            средний срок работы с клиентом 1.5 года. E-commerce и инфобиз курирует
            Магош. Все лиды в нише знают цифры по нише наизусть: средний CPL, средний
            ROAS, что работает в креативах, а что выгорает за неделю.
          </p>
        </div>

        <div class="card">
          <h3>Кейсы, которые можно показать</h3>
          <p>
            200+ проектов за 8 лет дают конкретные цифры для любого разговора. Не
            «у нас был кейс похожий на ваш», а «в марте 2025 мы запускали похожий
            проект с таким-то бюджетом, вот что получилось». Это меняет разговор
            с клиентом: обсуждаем реалистичные прогнозы, а не обещания.
          </p>
        </div>

        <div class="card">
          <h3>Готовые шаблоны воронок</h3>
          <p>
            Для каждой ниши у нас отработан стандартный стек: лендинг, квиз, креативы,
            CRM-интеграции, скрипты продаж, карта аналитики. На старте нового проекта
            90% этого применяется сразу, оставшиеся 10% затачиваем под специфику
            клиента. Это сокращает срок от договора до первых лидов до 7-14 дней.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section id="industries-list" class="section bg-dark">
    <div class="container">
      <Label text="Направления" />
      <h2 class="section-title">Выберите свою отрасль</h2>

      <div class="ind-grid">
        {industries.map(ind => (
          <a href={`/industries/${ind.id}/`} class={`ind-card ${ind.highlight ? 'ind-card-hl' : ''}`}>
            <div class="ind-order">0{ind.order}</div>
            <h3>{ind.title}</h3>
            <p class="ind-case">{ind.titleCase}</p>
            <p class="ind-desc">{ind.shortDescription}</p>
            {ind.keyMetric && <div class="ind-metric">{ind.keyMetric}</div>}
            <div class="ind-count">
              {ind.casesCount} {ind.casesCount === 1 ? 'кейс' : (ind.casesCount > 4 ? 'кейсов' : 'кейса')} в портфеле
            </div>
            <span class="ind-more">Подробный разбор →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section id="cross-nishes" class="section">
    <div class="container narrow">
      <Label text="Что если" />
      <h2>Ваша ниша не попадает ни в одну из шести?</h2>
      <p>
        Шесть направлений - это не жесткие границы. За 8 лет мы работали с нишами,
        которые формально не попадают в этот список: автоимпорт из Грузии, фитнес-клубы,
        юридические услуги (банкротство, госрегистрации), детские центры, франшизы
        любого типа. В портфеле есть и более редкие проекты: яхтенная компания на
        Пхукете, школа сомелье в Москве, сервис подбора автомобилей, подрядчик по
        ремонту фасадов для управляющих компаний.
      </p>

      <p>
        Логика принятия нового проекта простая. Если ниша смежна с одной из шести
        основных - берем без вопросов и ведет соответствующая команда. Например,
        автоимпорт Грузия-РФ мы отнесли к e-commerce, потому что воронка похожая:
        визуальный продукт, импульсная покупка, работа с возражениями через
        видео-отзывы. Если ниша совсем новая для нас - договариваемся тестовый
        период 2-3 месяца с фиксированным бюджетом и пишем план развития. Не беремся
        только за запрещенные и серые ниши: MLM, букмекеры, казино, микрозаймы,
        БАДы без лицензии.
      </p>

      <ul class="related-links">
        <li>
          <a href="/portfolio/">
            Портфолио с фильтром по нише - 17 детальных Astro-кейсов плюс 58
            кейсов в архиве
          </a>
        </li>
        <li>
          <a href="/services/">
            Страницы услуг, если хотите разобраться по каналам, а не по нишам
          </a>
        </li>
        <li>
          <a href="/real-estate/">
            Страницы по странам, если у вас недвижимость - там детальный разбор
            по семи рынкам
          </a>
        </li>
      </ul>
    </div>
  </section>

  <section id="faq" class="section">
    <div class="container narrow">
      <Faq tag="industries" title="Короткие ответы на частые вопросы" label="FAQ" />
    </div>
  </section>

  <StickyMobileCta targetHash="#form-final" label="Обсудить проект" />

  <CtaSection
    title="Расскажите, в какой вы нише"
    description="Бесплатная 40-минутная встреча с профильным лид-специалистом вашего направления. Обсудим цели, посмотрим текущие кабинеты, обсудим каналы под ваш чек и рынок. Кейсы покажем из вашей ниши и сегмента."
    leadSource="industries"
    contentCategory="industries"
    formTitle="Оставить заявку"
    bullets={[
      'Подберем команду под вашу нишу',
      'Покажем кейсы из вашего сегмента',
      'Обсудим реалистичный прогноз по CPL и CPA',
    ]}
  />
</BaseLayout>

<style>
  .ind-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 40px;
  }
  @media (max-width: 900px) {
    .ind-grid { grid-template-columns: 1fr; }
  }

  .ind-card {
    display: flex;
    flex-direction: column;
    padding: 28px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    text-decoration: none;
    color: inherit;
    transition: all 0.25s;
  }
  .ind-card:hover {
    border-color: rgba(201, 168, 76, 0.35);
    transform: translateY(-2px);
  }
  .ind-card-hl {
    border-color: rgba(201, 168, 76, 0.25);
  }

  .ind-order {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--gold);
    letter-spacing: 0.1em;
    margin-bottom: 14px;
  }
  .ind-card h3 {
    font-size: 1.45rem;
    font-weight: 600;
    margin: 0 0 8px;
  }
  .ind-case {
    font-size: 0.85rem;
    color: var(--text-dim);
    margin: 0 0 14px;
    line-height: 1.5;
  }
  .ind-desc {
    font-size: 0.85rem;
    line-height: 1.6;
    margin: 0 0 16px;
  }
  .ind-metric {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--gold);
    padding: 8px 10px;
    background: var(--gold-dim);
    border-radius: 6px;
    margin-bottom: 14px;
    letter-spacing: 0.02em;
  }
  .ind-count {
    font-size: 0.78rem;
    color: var(--text-dim);
    margin-bottom: 18px;
  }
  .ind-more {
    margin-top: auto;
    font-size: 0.85rem;
    color: var(--gold);
    font-weight: 500;
  }
</style>
