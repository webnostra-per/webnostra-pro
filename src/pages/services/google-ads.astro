---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/ui/Breadcrumbs.astro';
import HeroLeaf from '@components/hero/HeroLeaf.astro';
import Toc from '@components/ui/Toc.astro';
import StickyMobileCta from '@components/ui/StickyMobileCta.astro';
import CtaSection from '@components/sections/CtaSection.astro';
import Faq from '@components/sections/Faq.astro';
import Label from '@components/ui/Label.astro';

import QuickAnswer from '@components/seo/QuickAnswer.astro';
import LastUpdated from '@components/seo/LastUpdated.astro';
import { serviceSchema } from '@lib/seo';
const title = 'Google Ads для бизнеса в Дубае, ЮВА и англоязычных рынках | WEBNOSTRA PERFORMANCE';
const description =
  'Настройка и ведение Google Ads для недвижимости в Дубае и на Бали, B2B-проектов, экспатских сервисов и англоязычных e-commerce. Performance Max под контролем, сквозная аналитика, передача офлайн-конверсий.';
const canonical = 'https://webnostra.pro/services/google-ads/';

const breadcrumbs = [
  { name: 'Главная', url: '/' },
  { name: 'Услуги', url: '/services/' },
  { name: 'Google Ads', url: '/services/google-ads/' },
];

const toc = [
  { id: 'dlya-kogo', label: 'Для кого работает канал' },
  { id: 'problemy', label: 'Проблемы на которые мы заходим' },
  { id: 'podkhod', label: 'Наш подход' },
  { id: 'instrumenty', label: 'Инструменты и форматы' },
  { id: 'keysy', label: 'Кейсы с цифрами' },
  { id: 'otlichiya', label: 'Чем мы отличаемся' },
  { id: 'process', label: 'Процесс работы' },
  { id: 'faq', label: 'Вопросы и ответы' },
  { id: 'form-final', label: 'Обсудить проект' },
];

const schema = serviceSchema({
  name: 'Настройка и ведение Google Ads',
  description: 'Ведение Google Ads и Performance Max для международных проектов: Дубай, Бали, Таиланд, Европа, США. Поиск, Shopping, YouTube, Discovery, Enhanced Conversions.',
  path: '/services/google-ads/',
  serviceType: 'Google Ads Advertising',
});
---

<BaseLayout title={title} description={description} canonical={canonical} structuredData={schema}>
  <HeroLeaf
    label="Услуга · Google Ads"
    title="Google Ads, где мы разгребаем Performance Max и возвращаем контроль над трафиком"
    description="Канал для бизнеса в Дубае, на Бали, в Таиланде и Турции на англоязычную аудиторию. Для B2B-проектов и экспортных e-commerce. Работаем там, где Google реально дает результат, а не потому что его просто принято запускать."
    ctaText="Обсудить проект"
    ctaHref="#form-final"
    breadcrumbs={breadcrumbs}
  />

  <LastUpdated date="22 апреля 2026" version="v1.0" author={{ name: "Магош Альшанский", url: "/authors/magosh/" }} />

  <QuickAnswer
    title="Google Ads агентство для международных рынков"
    summary="Google Ads - флагманский канал для Дубая, Пхукета, Бали, глобальных e-commerce проектов. Работаем с Search, Performance Max, YouTube Ads. Оптимизация на конкретные типы конверсий, а не на базовые события."
    items={[
      { label: "Приоритетные гео", value: "Дубай, Пхукет, Бали, EN-рынки, премиум-сегменты" },
      { label: "Пример результата", value: "Имплантация в Праге - ROI 760% за 28 дней в связке с Meta Ads" },
      { label: "Минимальный бюджет", value: "$3,000 в месяц для тестов, $10,000+ для масштабирования" },
      { label: "Срок запуска", value: "48 часов" },
      { label: "Работа с PMax", value: "Обязательная настройка feed-based signals и исключений, иначе PMax сливает бюджет" },
      { label: "Языки кампаний", value: "RU, EN, AR, CN - нативные копирайтеры in-house" },
    ]}
  />

  <Toc items={toc} />

  <section id="dlya-kogo" class="section">
    <div class="container narrow">
      <Label text="Кому подходит" />
      <h2>Для кого Google - один из основных каналов</h2>
      <p>
        Начнем с честного: для нашей аудитории (русскоязычные клиенты из РФ и СНГ) Google
        не всегда основной канал. На российском рынке Яндекс берет большую часть поиска,
        на китайском и арабском есть свои платформы. Но там, где аудитория
        англоязычная или мультиязычная, Google остается обязательным каналом с самым
        прогретым интентом на поиске.
      </p>

      <div class="grid cols-2">
        <div class="card">
          <h3>Недвижимость Дубая, Бали, Таиланда на англоязычную аудиторию</h3>
          <p>
            Европейцы, американцы, азиаты, экспаты из CIS стран, которые ищут инвестиционную
            недвижимость или второе жилье. На Google у них сформированный запрос типа
            "villas phuket for sale", "dubai apartments investment", "bali leasehold
            property". Канал собирает горячий поисковый спрос, Meta добирает теплую
            аудиторию. Подробнее - на страницах
            <a href="/real-estate/dubai/">Дубай</a>,
            <a href="/real-estate/bali/">Бали</a> и
            <a href="/real-estate/thailand/">Таиланд</a>.
          </p>
        </div>

        <div class="card">
          <h3>B2B-проекты и профессиональные услуги</h3>
          <p>
            Юридические и финансовые сервисы, ИТ-компании, консалтинг, SaaS. Там, где
            человек ищет решение по конкретному деловому запросу - Google Search работает
            лучше всего. Здесь мало картинок и эмоций, но много конверсии из горячего
            спроса. Если у вас длинная B2B-воронка - Google дает верхний уровень притока.
          </p>
        </div>

        <div class="card">
          <h3>Экспатские сервисы в ЮВА и Дубае</h3>
          <p>
            Аренда мебели, автомобилей, оформление ВНЖ, страхование, медицинские услуги,
            школы для детей экспатов. Аудитория - люди, живущие в Дубае или Таиланде 1-3
            года, которые ищут сервисы на английском. Google Search - канал, где они
            стартуют поиск поставщика.
          </p>
        </div>

        <div class="card">
          <h3>Экспортный и нишевый e-commerce</h3>
          <p>
            Когда продукт продается на английском или европейском рынке. Коллекционные
            товары, хенд-мейд, дизайн, нишевая косметика. Google Shopping и Performance
            Max закрывают нижний уровень воронки на готовых покупателей. Пример из нашей
            практики - SamoilovART: шлемы Star
            Wars в США, 47 продаж по $320 на бюджете $2,150 (реклама шла в Meta, но
            смежная модель для Google - та же).
          </p>
        </div>

        <div class="card">
          <h3>Туризм и санатории в странах с сильной позицией Google</h3>
          <p>
            В Украине, Беларуси, Казахстане и некоторых странах СНГ Google держит
            большую долю поиска, чем в РФ. Для туризма, санаторного бизнеса и
            бронирований это - основной канал холодного спроса. Кейс клинического
            санатория им. Пирогова в Одессе: 1,241 заявка по 325 грн, конверсия 16% на
            бюджете 403,000 грн.
          </p>
        </div>

        <div class="card muted">
          <h3>Когда Google - не основной канал</h3>
          <p>
            Бизнес в РФ на русскоязычную аудиторию: берите <a
              href="/services/yandex-direct/">Яндекс Директ</a
            > как основу. Продажи в Крыму или новых регионах: там работает только <a
              href="/services/vk-ads/">VK</a
            >. Массовый локальный e-commerce в России: Google даст 5-10% прироста, но
            основа - Яндекс. Для русскоязычных инвесторов в Дубае или Таиланде -
            основным каналом берется <a href="/services/meta-ads/">Meta Ads</a>, Google
            идет догоняющим.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section id="problemy" class="section bg-dark">
    <div class="container narrow">
      <Label text="Проблемы" />
      <h2>С чем приходят клиенты, которые уже пробовали Google</h2>

      <ol class="problems-list">
        <li>
          <h3>Performance Max съедает бюджет без отчета, что работает</h3>
          <p>
            PMax - черный ящик. Вы видите итоговые цифры, но не видите какие креативы,
            какие плейсменты, какие аудитории на самом деле приносят конверсии. У Google
            это сделано намеренно. Мы вытаскиваем данные через Insights API, скрипты и
            Asset Group Reports, делим кампании по asset groups под отдельные цели,
            исключаем мусорные плейсменты через account-level placement exclusions.
          </p>
        </li>

        <li>
          <h3>Нет конверсий в CRM - Google учится на "отправил форму"</h3>
          <p>
            Базовая ошибка: в Google Ads настроен event "form submission" как главная
            конверсия. Алгоритм ищет тех, кто заполняет формы, а не тех, кто покупает. Мы
            настраиваем enhanced conversions, передаем стадии воронки через offline
            conversion import, привязываем CRM через Zapier или нативные интеграции.
            Алгоритм начинает оптимизироваться на квалифицированного лида.
          </p>
        </li>

        <li>
          <h3>Брендовый и небрендовый трафик в одной куче</h3>
          <p>
            Частая история: аккаунт показывает отличный CPL, а при разделении на
            брендовый и небрендовый трафик выясняется, что 70% конверсий - по брендовым
            запросам, которые пришли с Instagram или с прямых заходов. Мы делим кампании
            на брендовые и небрендовые, оцениваем отдельно, не приписываем заслугу
            Google там, где он только замыкал путь пользователя.
          </p>
        </li>

        <li>
          <h3>Один лендинг на все языки и все гео</h3>
          <p>
            Для Дубая, Бали и Таиланда часто делают один английский сайт на всю Азию. Но
            аудитория разная: европейский инвестор, экспат из Казахстана, сингапурец,
            турок. Мы делаем языковые и региональные версии посадочных, квизы под
            сегменты, отдельные офферы в зависимости от страны пользователя.
          </p>
        </li>

        <li>
          <h3>Нет Google Tag Manager и server-side трекинга</h3>
          <p>
            В 2026 году без GTM и server-side треккинга часть конверсий теряется из-за
            ITP, блокировщиков и истекающих cookie. Настраиваем Google Tag Manager
            Server-Side через Stape или собственный GCP-контейнер, увеличиваем точность
            трекинга на 15-30%.
          </p>
        </li>

        <li>
          <h3>Подозрительный трафик и клик-фрод</h3>
          <p>
            На конкурентных нишах (Дубай, юридические услуги, ремонт) встречается
            ботовый и фрод-трафик от конкурентов и партнерских сетей GDN. Мы
            подключаем ClickCease или Lunio для фильтрации, настраиваем правила
            исключения плейсментов, следим за аномалиями в ClickView.
          </p>
        </li>
      </ol>
    </div>
  </section>

  <section id="podkhod" class="section">
    <div class="container narrow">
      <Label text="Подход" />
      <h2>Шесть принципов ведения Google, от которых не отступаем</h2>

      <div class="grid cols-2">
        <div class="card">
          <h3>1. Сначала решаем, нужен ли вообще Google</h3>
          <p>
            До первого доллара в Google считаем - а насколько канал релевантен вашей
            аудитории и продукту. Если ваш покупатель в РФ и ищет в Яндексе, а Google
            предлагается "чтобы было" - откровенно говорим не тратить деньги. У нас в
            портфеле только проекты, где Google реально дает экономику.
          </p>
        </div>

        <div class="card">
          <h3>2. Search и Performance Max разделены жестко</h3>
          <p>
            Search работает на горячий поисковый спрос, PMax - на охватную автоматику.
            Это разные механики, разные целевые CPA, разная структура кампаний. Никогда
            не запускаем PMax на бренд или на те же ключи, что в Search - Google сам
            начинает каннибализировать брендовый трафик.
          </p>
        </div>

        <div class="card">
          <h3>3. Enhanced conversions и офлайн-импорт обязательны</h3>
          <p>
            Без enhanced conversions с хешированием email и телефона Google теряет до
            30% конверсий на iOS. Без офлайн-импорта сделок из CRM алгоритм учится на
            заявке, а не на продаже. Настраиваем оба механизма в первые 2 недели работы.
          </p>
        </div>

        <div class="card">
          <h3>4. Специализация по нишам</h3>
          <p>
            Как и в остальных каналах, у нас пять профильных performance-команд. Google
            для недвижимости в Дубае ведут те, кто уже запускал 5-7 аналогичных
            проектов. Для B2B и экспортного e-commerce - отдельная подгруппа со своими
            связками и тестами.
          </p>
        </div>

        <div class="card">
          <h3>5. Ежемесячная работа с семантикой и поисковыми запросами</h3>
          <p>
            Раз в месяц: отчет по search terms, добавление релевантных ключей в точные
            соответствия, минусация мусорных фраз, переоценка приоритетов по CPA. В
            Google семантика живет еще более подвижно, чем в Яндексе - за квартал без
            работы кабинет теряет 20-30% эффективности.
          </p>
        </div>

        <div class="card">
          <h3>6. Прозрачная отчетность и доступы</h3>
          <p>
            Агентский кабинет Google Ads с прозрачной историей платежей. Вся аналитика
            в Looker Studio - ежедневные обновления. Доступы у клиента на чтение и
            стандартный, мы сохраняем доступ на редактирование. После расторжения
            клиент забирает весь аккаунт и историю.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section id="instrumenty" class="section bg-dark">
    <div class="container narrow">
      <Label text="Инструменты" />
      <h2>Что у нас в стеке по Google Ads</h2>

      <div class="grid cols-3">
        <div class="card">
          <h3>Типы кампаний</h3>
          <ul>
            <li>Search - поисковые по ключам</li>
            <li>Performance Max с контролем asset groups</li>
            <li>Shopping и Google Merchant Center</li>
            <li>Display Network (GDN) по интересам</li>
            <li>YouTube Ads (in-stream, bumper, discovery)</li>
            <li>Demand Gen - для визуальных продуктов</li>
            <li>App Campaigns для мобильных приложений</li>
          </ul>
        </div>

        <div class="card">
          <h3>Аналитика и трекинг</h3>
          <ul>
            <li>GA4 с настройкой events и conversions</li>
            <li>Google Tag Manager (web и server-side)</li>
            <li>Enhanced Conversions для iOS-трафика</li>
            <li>Offline conversion import из CRM</li>
            <li>Looker Studio для дашбордов</li>
            <li>BigQuery для глубокой аналитики</li>
            <li>ClickCease, Lunio - защита от фрода</li>
          </ul>
        </div>

        <div class="card">
          <h3>Семантика и аудитории</h3>
          <ul>
            <li>Кластеризация через Keyword Planner и Ahrefs</li>
            <li>Работа с модификаторами (exact, phrase, broad)</li>
            <li>Custom Audiences из CRM</li>
            <li>Similar Audiences по сегментам</li>
            <li>In-market и affinity audiences</li>
            <li>Customer Match с импортом email-баз</li>
          </ul>
        </div>

        <div class="card">
          <h3>Посадочные и квизы</h3>
          <ul>
            <li>Языковые версии (EN, RU, AR по нише)</li>
            <li>Квизы с логикой под сегмент аудитории</li>
            <li>A/B-тесты первого экрана и оффера</li>
            <li>Calculator-виджеты для недвижимости</li>
            <li>Скорость Core Web Vitals - зеленые метрики</li>
            <li>Мобильная оптимизация first</li>
          </ul>
        </div>

        <div class="card">
          <h3>Креативы и объявления</h3>
          <ul>
            <li>Responsive Search Ads с 15 заголовками и 4 описаниями</li>
            <li>Баннеры в 12+ форматах для GDN и Discovery</li>
            <li>Видеообъявления для YouTube - 6s, 15s, 30s</li>
            <li>Assets для Performance Max (image, video, text)</li>
            <li>Локализация креативов под рынки</li>
            <li>Продакшн in-house - дизайнер, моушн, копирайтер</li>
          </ul>
        </div>

        <div class="card">
          <h3>Юридическая и финансовая сторона</h3>
          <ul>
            <li>Оплата через зарубежные юрлица (Таиланд, Кипр)</li>
            <li>Инвойсы в USD или EUR для не-РФ клиентов</li>
            <li>Закрывающие документы с НДС для РФ</li>
            <li>Manager account для управления множеством проектов</li>
            <li>Решение вопросов с блокировками и политиками</li>
            <li>Сертификация Google Partner (внутренний статус)</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section id="keysy" class="section">
    <div class="container narrow">
      <Label text="Кейсы" />
      <h2>Три проекта, где Google сыграл ключевую роль</h2>
      <p>
        Проекты из разных стран и ниш. Полные разборы - по ссылкам в конце каждого блока.
      </p>

      <article class="case-inline">
        <div class="case-head">
          <span class="case-pill">Недвижимость · Пхукет, Таиланд</span>
          <h3>Premium Villas Phuket - 7 сделок по $450K через связку Meta и Google</h3>
        </div>

        <p>
          Премиальные виллы на Пхукете, средний чек $450K, цикл сделки 3-6 месяцев.
          Клиенты (европейцы, американцы, китайцы) смотрят по 20-30 объектов перед
          покупкой. Задача - собрать поток квалифицированных лидов и дать менеджерам
          длинную воронку для дожима.
        </p>

        <p>
          Что сделали: Google Search работал на горячий поисковой спрос ("luxury villa
          phuket for sale", "phuket property investment"), Meta - на look-alike от
          покупателей и интересы к роскошному образу жизни. Создали интерактивный
          каталог с VR-турами, онлайн-встречи с менеджером прямо из виллы,
          калькулятор доходности от сдачи в аренду. Enhanced Conversions передавал
          данные о квал-лидах в Google, алгоритм оптимизировался не на заявку, а на
          встречу с менеджером.
        </p>

        <div class="case-numbers">
          <div><span>89</span><em>квал. лидов</em></div>
          <div><span>7</span><em>сделок</em></div>
          <div><span>$450K</span><em>средний чек</em></div>
          <div><span>$3.2M</span><em>pipeline</em></div>
        </div>

        <a class="case-link" href="/portfolio/premium-villas-phuket/"
          >Полный кейс Premium Villas →</a
        >
      </article>

      <article class="case-inline">
        <div class="case-head">
          <span class="case-pill">Туризм и медицина · Одесса, Украина</span>
          <h3>
            Санаторий им. Пирогова - 1,241 заявка по 325 грн через Google в сложный
            период
          </h3>
        </div>

