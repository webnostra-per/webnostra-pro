---
import BaseLayout from '@layouts/BaseLayout.astro';
import HeroHub from '@components/hero/HeroHub.astro';
import CtaSection from '@components/sections/CtaSection.astro';
import Faq from '@components/sections/Faq.astro';
import Label from '@components/ui/Label.astro';
import StickyMobileCta from '@components/ui/StickyMobileCta.astro';

const title = 'Услуги WEBNOSTRA PERFORMANCE - реклама, креативы, аналитика и поддержка продаж';
const description =
  'Семь направлений работы: Meta Ads, Яндекс Директ, Google Ads, VK Ads, производство креативов, сквозная аналитика и поддержка отдела продаж. Под каждую нишу - профильная performance-команда.';
const canonical = 'https://webnostra.pro/services/';

const breadcrumbs = [
  { name: 'Главная', url: '/' },
  { name: 'Услуги', url: '/services/' },
];

const heroMeta = [
  { value: '7', label: 'направлений работы' },
  { value: '5', label: 'performance-команд под ниши' },
  { value: '200+', label: 'проектов в портфеле' },
];

const channels = [
  {
    tag: 'Канал',
    title: 'Meta Ads',
    subtitle: 'Facebook и Instagram',
    description:
      'Для недвижимости ЮВА и Дубая, e-commerce, инфобиза, туризма. Кейсы: $34 за квал-лид на Пхукете, ROI 320% на яхтах, $3.17 за лид на школе программирования.',
    href: '/services/meta-ads/',
  },
  {
    tag: 'Канал',
    title: 'Яндекс Директ',
    subtitle: 'Флагман для РФ и СНГ',
    description:
      'Для e-commerce, инфобиза, недвижимости РФ, медицины, туризма. Кейсы: 210М руб выручки на алкогольной витрине, 492 руб за лид в санаторной нише, ROI 520%.',
    href: '/services/yandex-direct/',
  },
  {
    tag: 'Канал',
    title: 'Google Ads',
    subtitle: 'Дубай, Бали и англоязычная аудитория',
    description:
      'Для недвижимости Дубая и Бали, B2B-проектов, экспатских сервисов, экспортного e-commerce. Вскрываем Performance Max, настраиваем enhanced conversions, защищаем от фрода.',
    href: '/services/google-ads/',
  },
  {
    tag: 'Канал',
    title: 'VK Ads',
    subtitle: 'Крым, инфобиз РФ, детские услуги',
    description:
      'Единственный рабочий канал для Крыма и новых регионов. Для инфобиза с массовой аудиторией, детских услуг, бьюти. Кейсы: 686 квал-лидов, ROI 562% на детском центре.',
    href: '/services/vk-ads/',
  },
  {
    tag: 'Продакшн',
    title: 'Производство креативов',
    subtitle: 'In-house команда',
    description:
      '8-15 креативов в неделю. Статика, моушн, видео, UGC, дрон-съемка. Команда на Пхукете для съемки объектов недвижимости. RU, EN, AR, CN локализация.',
    href: '/services/creatives/',
  },
  {
    tag: 'Данные',
    title: 'Сквозная аналитика',
    subtitle: 'Фундамент под остальное',
    description:
      'Roistat, Calltouch, Comagic, Looker Studio, BigQuery. Передача оффлайн-конверсий из CRM, server-side трекинг, когортный анализ LTV. Снижает CAC на 30-50%.',
    href: '/services/analytics/',
  },
  {
    tag: 'Продажи',
    title: 'Поддержка отдела продаж',
    subtitle: 'CRM, обучение, контроль качества',
    description:
      'Внедрение Bitrix24 и amoCRM, квалификация лидов, контроль качества звонков, обучение менеджеров, мотивация, помощь с наймом РОПа. Внутри ведения рекламы, не отдельным продуктом.',
    href: '/services/sales-support/',
  },
];
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <HeroHub
    label="Услуги"
    title="Семь направлений работы, которые складываются в одну систему продаж"
    description="Мы не продаем услуги по отдельности. Реклама без аналитики работает вслепую. Аналитика без отдела продаж - красивый отчет, который ни к чему не ведет. Креативы без трафик-команды - дорогие картинки. Поэтому у нас все это в одной связке, ведут профильные performance-команды под ниши."
    meta={heroMeta}
    breadcrumbs={breadcrumbs}
  />

  <section id="napravleniya" class="section">
    <div class="container narrow">
      <Label text="Направления" />
      <h2>Четыре рекламных канала, продакшн, аналитика и продажи</h2>
      <p>
        Четыре канала работают с разными рынками и разными аудиториями: Meta - для
        ЮВА и Дубая, Яндекс - для РФ и СНГ, Google - для англоязычных и B2B, VK -
        для Крыма, инфобиза и локальных услуг. Поверх каналов - три базовых
        услуги, которые делают рекламу управляемой системой, а не лотереей.
      </p>

      <div class="grid cols-2">
        {channels.map((ch) => (
          <a class="service-card" href={ch.href}>
            <div class="service-card__tag">{ch.tag}</div>
            <h3>{ch.title}</h3>
            <div class="service-card__subtitle">{ch.subtitle}</div>
            <p>{ch.description}</p>
            <span class="service-card__link">Подробнее →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section id="svyaz" class="section bg-dark">
    <div class="container narrow">
      <Label text="Связка" />
      <h2>Почему услуги работают только вместе</h2>

      <div class="grid cols-2">
        <div class="card">
          <h3>Канал без аналитики - слив бюджета</h3>
          <p>
            Meta или Директ без правильно настроенных оффлайн-конверсий
            оптимизируется на «заполнил форму». Алгоритм ищет лидогенераторов, а не
            покупателей. CPL низкий, а CAC - в 2-3 раза выше нормы. Поэтому базовая
            <a href="/services/analytics/">сквозная аналитика</a> с передачей
            квал-лидов и сделок в кабинеты - фундамент любого нашего проекта.
          </p>
        </div>

        <div class="card">
          <h3>Аналитика без отдела продаж - мусорные данные</h3>
          <p>
            Самая точная аналитика не поможет, если менеджеры не заполняют CRM или
            заполняют как попало. Именно поэтому мы идем в
            <a href="/services/sales-support/">отдел продаж клиента</a>: ставим SLA на
            первый звонок, вводим обязательные поля, подключаем наш in-house отдел
            контроля качества для еженедельного прослушивания звонков.
          </p>
        </div>

        <div class="card">
          <h3>Трафик без креативов - выгорание за неделю</h3>
          <p>
            Один креатив крутится 7-10 дней, CTR падает, CPM растет. Без постоянного
            потока новых креативов реклама превращается в свечку. Наш
            <a href="/services/creatives/">in-house продакшн</a> дает 8-15
            новых креативов в неделю с адаптациями под каждый канал и язык.
          </p>
        </div>

        <div class="card">
          <h3>Команды под ниши, а не универсальный отдел</h3>
          <p>
            В обычном агентстве один таргетолог ведет застройщика, интернет-магазин и
            онлайн-школу. Это ломает экспертизу. У нас пять профильных performance-
            команд: недвижимость, e-commerce, инфобиз, туризм, медицина. Вашим
            проектом занимаются те, кто уже сделал десятки аналогичных.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section id="komandy" class="section">
    <div class="container narrow">
      <Label text="Команды" />
      <h2>Пять performance-команд под каждую нишу</h2>
      <p>
        Типовое агентство держит один таргетологический отдел, в котором один и тот
        же специалист утром ведет застройщика, днем - онлайн-школу, вечером -
        интернет-магазин косметики. Это ломает глубину экспертизы: связки из одной
        ниши не переносятся в другую, типовые ошибки повторяются, специалист не
        успевает вникать в специфику. Наша схема - другая.
      </p>

      <div class="grid cols-2">
        <div class="card">
          <h3>Команда недвижимости</h3>
          <p>
            Специализация на ЮВА, Дубае и РФ. Опыт в полном цикле: от первого клика
            до сделки с чеком $80-500K. Meta для русскоязычных инвесторов, Google
            для англоязычных, Директ и VK для РФ. Под рукой - команда съемки на
            Пхукете для живого продакшена объектов.
          </p>
        </div>

        <div class="card">
          <h3>Команда e-commerce</h3>
          <p>
            Интернет-магазины, маркетплейсы, D2C-бренды, B2B-поставщики. Сильные
            знания по товарным фидам, динамическим объявлениям, когортной
            экономике и LTV. Кейсы с масштабированием бюджетов от сотен тысяч
            рублей до миллионов в месяц без роста CPO.
          </p>
        </div>

        <div class="card">
          <h3>Команда инфобиза и EdTech</h3>
          <p>
            Онлайн-школы, курсы, вебинары, коучинг, детские образовательные
            проекты. Работа с длинными прогревочными воронками, КЭВ-встречами,
            автоворонками через чат-боты. Экспертиза по Meta для СНГ, Казахстана,
            Беларуси и Директу для РФ.
          </p>
        </div>

        <div class="card">
          <h3>Команды туризма и медицины</h3>
          <p>
            Туризм - экскурсионные компании, отели, турагентства, санатории.
            Медицина - клиники, стоматология, косметология, реабилитация. Обе
            ниши требуют тонкой работы с сезонностью, квалификацией лидов по
            медицинским показаниям или целям поездки, локальным таргетом и
            возвратами через ретаргет и базы клиентов.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section id="kak-nachat" class="section bg-dark">
    <div class="container narrow">
      <Label text="Как начать" />
      <h2>Куда заходить в зависимости от задачи</h2>

      <div class="grid cols-2">
        <div class="card">
          <h3>Если нужен конкретный канал</h3>
          <p>
            Посмотрите страницу этого канала: там разбор, для кого работает, кейсы
            из нужной ниши и медиаплан. Главные каналы у нас -
            <a href="/services/meta-ads/">Meta Ads</a> для ЮВА и Дубая,
            <a href="/services/yandex-direct/">Яндекс Директ</a> для РФ,
            <a href="/services/vk-ads/">VK Ads</a> для Крыма и инфобиза,
            <a href="/services/google-ads/">Google Ads</a> для англоязычного
            рынка и B2B.
          </p>
        </div>

        <div class="card">
          <h3>Если непонятно, какой канал подходит</h3>
          <p>
            Оставьте заявку на бесплатную 40-минутную диагностику. Обсудим продукт и
            аудиторию, посчитаем юнит-экономику, дадим рекомендацию, какой канал или
            связка каналов подходит вашему бизнесу. Если канал не наш профиль -
            честно скажем и порекомендуем другое агентство.
          </p>
        </div>

        <div class="card">
          <h3>Если реклама уже идет, но результат слабый</h3>
          <p>
            Делаем аудит текущего сетапа: рекламные кабинеты, аналитика, CRM,
            посадочные. Показываем, где теряется бюджет и где точки роста.
            Аудит бесплатный, если после него идем в работу. Если не идем -
            фиксируем за фиксированную сумму на старте.
          </p>
        </div>

        <div class="card">
          <h3>Если проблема в продажах, а не в трафике</h3>
          <p>
            Разбираемся с отделом продаж перед тем как увеличивать бюджет на
            рекламу. Наша <a href="/services/sales-support/">поддержка отдела продаж</a
            > входит в ведение рекламы: если менеджеры теряют лиды, никакой трафик
            не спасет юнит-экономику.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section id="faq" class="section">
    <div class="container narrow">
      <Faq tag="general" title="Короткие ответы на частые вопросы" label="FAQ" />
    </div>
  </section>

  <StickyMobileCta targetHash="#form-final" label="Обсудить проект" />

  <CtaSection
    title="Обсудим ваш проект"
    description="Бесплатная 40-минутная встреча. Разберем продукт и рынок, посчитаем медиаплан, дадим прогноз по лидам и CAC. Если видим что наша специализация не подходит под вашу задачу - честно скажем и порекомендуем другое агентство."
    leadSource="services_hub"
    formTitle="Получить расчет"
  />
</BaseLayout>
