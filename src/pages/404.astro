---
import BaseLayout from '@layouts/BaseLayout.astro';
import Button from '@components/ui/Button.astro';
---

<BaseLayout
  title="404 - страница не найдена | WEBNOSTRA"
  description="Страница не найдена. Вернитесь на главную или посмотрите наши кейсы."
  noindex={true}
  showStickyCta={false}
>
  <section class="notfound">
    <div class="container">
      <div class="notfound-inner">
        <div class="notfound-code">404</div>
        <h1>Страница не найдена</h1>
        <p>Такой страницы нет или она была перемещена. Давайте вернем вас на правильный путь.</p>
        <div class="notfound-ctas">
          <Button href="/" variant="primary" arrow={false}>На главную</Button>
          <Button href="/portfolio/" variant="secondary">Смотреть кейсы</Button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .notfound {
    min-height: calc(100vh - 68px);
    display: flex;
    align-items: center;
  }
  .notfound-inner {
    max-width: 560px;
    margin: 0 auto;
    text-align: center;
    padding: 80px 20px;
  }
  .notfound-code {
    font-family: var(--font-display);
    font-size: clamp(5rem, 12vw, 8rem);
    font-weight: 700;
    color: var(--gold);
    opacity: 0.3;
    line-height: 1;
    margin-bottom: 16px;
    letter-spacing: -0.05em;
  }
  .notfound h1 {
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    margin-bottom: 16px;
  }
  .notfound p {
    color: var(--text-dim);
    margin-bottom: 32px;
    line-height: 1.7;
  }
  .notfound-ctas {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
