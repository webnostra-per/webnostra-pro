---
import BaseLayout from '@layouts/BaseLayout.astro';
import HeroLeaf from '@components/hero/HeroLeaf.astro';
import Toc from '@components/ui/Toc.astro';
import StickyMobileCta from '@components/ui/StickyMobileCta.astro';
import CtaSection from '@components/sections/CtaSection.astro';
import Faq from '@components/sections/Faq.astro';
import Label from '@components/ui/Label.astro';

const title = 'Реклама недвижимости в Грузии - Тбилиси, Батуми, Кутаиси - WEBNOSTRA PERFORMANCE';
const description =
  'Performance-маркетинг для застройщиков и агентств недвижимости в Грузии. Работаем в Тбилиси, Батуми, Кутаиси. Русскоязычные релоканты и инвесторы, апартаменты от $40K, безвизовый режим для РФ, ВНЖ через покупку от $100K. Батуми - курортная недвижимость под краткосрочную сдачу.';
const canonical = 'https://webnostra.pro/real-estate/georgia/';

const breadcrumbs = [
  { name: 'Главная', url: '/' },
  { name: 'Недвижимость', url: '/real-estate/' },
  { name: 'Грузия', url: '/real-estate/georgia/' },
];

const toc = [
  { id: 'dlya-kogo', label: 'Для кого работает рынок' },
  { id: 'specifika', label: 'Специфика рынка Грузии' },
  { id: 'kanaly', label: 'Каналы рекламы' },
  { id: 'podkhod', label: 'Как строим воронку' },
  { id: 'process', label: 'Процесс работы' },
  { id: 'faq', label: 'Вопросы и ответы' },
  { id: 'form-final', label: 'Обсудить проект' },
];
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <HeroLeaf
    label="Недвижимость · Грузия"
    title='Реклама недвижимости в Грузии для <span class="accent">русскоязычных релокантов и инвесторов</span>'
    description="Грузия - быстро растущий рынок после 2022 года. Основной драйвер - русскоязычные релоканты, которые выбирают Тбилиси для жизни и Батуми для курортных инвестиций. Апартаменты от $40K, безвизовый режим для граждан РФ, ВНЖ через покупку от $100K, налоги 1% для IP-статуса. Мы работаем с застройщиками и агентствами в основных трех городах."
    ctaText="Обсудить проект"
    ctaHref="#form-final"
    breadcrumbs={breadcrumbs}
  />

  <Toc items={toc} />

  <section id="dlya-kogo" class="section">
    <div class="container narrow">
      <Label text="Для кого" />
      <h2>Какие клиенты из Грузии к нам заходят</h2>
      <p>
        Рынок Грузии для иностранцев - это фактически два рынка в одной
        стране. Тбилиси - город для жизни, для релокации, для открытия
        бизнеса. Батуми - курортный рынок, где покупают под краткосрочную
        аренду и сезонную сдачу. Кутаиси - бюджетный сегмент, тихая
        альтернатива. Типичные клиенты:
      </p>

      <div class="grid cols-2">
        <div class="card">
          <h3>Застройщики в Тбилиси</h3>
          <p>
            Апартаменты от $50K (Дидубе, Глдани) до $300K+ (Ваке,
            Сабуртало, Вера). Аудитория - релоканты, которые переезжают
            жить, и инвесторы, покупающие под долгосрочную сдачу
            экспатам. Цикл покупки - 30-60 дней, важно качество контента
            и оперативность менеджера.
          </p>
        </div>

        <div class="card">
          <h3>Застройщики в Батуми</h3>
          <p>
            Прибрежные апартаменты и комплексы с бассейнами. Цены от $40K
            за студию до $200K за 2BR с видом на море. Основная модель -
            покупка под сдачу туристам через управляющую компанию.
            Обещаемая доходность 8-12% годовых. Реклама должна подробно
            разбирать эту математику.
          </p>
        </div>

        <div class="card">
          <h3>Агентства с мульти-брендовым пулом</h3>
          <p>
            Брокеры, работающие с десятками проектов одновременно.
            Нужна быстрая квалификация лидов по целям (жить, сдавать,
            инвестировать) и бюджету. Без квалификации менеджеры
            сливают время на нерелевантных.
          </p>
        </div>

        <div class="card">
          <h3>Проекты под долгосрочную аренду</h3>
          <p>
            Отдельный сегмент - релоканты, которые не покупают, а берут
            аренду на 1-2 года. Реклама под них другая: не про
            инвестиции, а про быстрое заселение, интернет, соседей,
            инфраструктуру для семей с детьми.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section id="specifika" class="section bg-dark">
    <div class="container narrow">
      <Label text="Специфика" />
      <h2>Что важно знать про рынок недвижимости Грузии</h2>

      <ul class="problems-list">
        <li>
          <strong>Безвизовый режим для РФ и быстрый ВНЖ.</strong> Граждане РФ
          могут въезжать в Грузию без визы на год. Покупка недвижимости
          от $100K дает право на ВНЖ. Это центральный аргумент для
          русскоязычных релокантов, и его нужно выносить в хедлайн.
        </li>
        <li>
          <strong>Налоговая модель IP-статуса.</strong> В Грузии есть
          статус индивидуального предпринимателя с налогом 1% от оборота
          до 500K лари ($180K) в год. Это привлекательно для фрилансеров
          и IT-специалистов. Покупка недвижимости + IP-статус = мощный
          пакет для аудитории digital-номадов.
        </li>
        <li>
          <strong>Полная собственность для иностранцев.</strong> В отличие от
          Таиланда, Бали или Индонезии, в Грузии иностранец может владеть
          землей и недвижимостью в полной собственности без ограничений.
          Это важный аргумент, особенно по сравнению с ЮВА.
        </li>
        <li>
          <strong>Рост цен после 2022 года.</strong> Рынок сильно вырос
          из-за притока русскоязычных. В некоторых районах Тбилиси цены
          выросли в 1,5-2 раза. Это создает и возможности (спрос высокий),
          и риски (пик может быть пройден). В рекламе нужна честная
          аналитика, а не хайп.
        </li>
        <li>
          <strong>Сезонность Батуми.</strong> В Батуми четко выражен
          сезон (май-октябрь). В низкий сезон доходность сдачи падает в
          3-5 раз. Реклама под инвестиции обязана показывать усредненную
          доходность, а не пиковую, иначе инвестор разочаруется через
          полгода.
        </li>
        <li>
          <strong>Локальный язык в креативах.</strong> Для небольшого
          сегмента локальных покупателей нужны креативы на грузинском.
          У нас есть партнерский копирайтер-натив для этих задач.
          Для основного русскоязычного сегмента грузинский не нужен.
        </li>
      </ul>
    </div>
  </section>

  <section id="kanaly" class="section">
    <div class="container narrow">
      <Label text="Каналы" />
      <h2>Какие каналы рекламы работают в Грузии</h2>

      <div class="grid cols-2">
        <div class="card">
          <h3>Meta Ads - основной канал</h3>
          <p>
            <a href="/services/meta-ads/">Meta Ads</a> - главный канал для
            русскоязычной и англоязычной аудитории. Instagram особенно
            сильный: визуальный продукт (Тбилиси и Батуми красивые),
            огромный охват релокантов. CPL $10-30 за квал-лида.
          </p>
        </div>

        <div class="card">
          <h3>Яндекс Директ для русского рынка</h3>
          <p>
            <a href="/services/yandex-direct/">Яндекс Директ</a> -
            основной канал для русскоязычных инвесторов из РФ, которые
            ищут Грузию из России. Поиск «купить квартиру Тбилиси», РСЯ
            с ретаргетом. Хороший канал для прогретой аудитории.
          </p>
        </div>

        <div class="card">
          <h3>Google Ads точечно</h3>
          <p>
            <a href="/services/google-ads/">Google Ads</a> - не основной,
            но рабочий канал для англоязычных экспатов и отдельных
            запросов. Объем небольшой по сравнению с Meta и Яндексом.
          </p>
        </div>

        <div class="card">
          <h3>Telegram-каналы релокантов</h3>
          <p>
            Мощный канал для Грузии. Множество русскоязычных каналов про
            релокацию, жизнь в Тбилиси, открытие бизнеса. Посевы в таких
            каналах дают теплых лидов, готовых к покупке. Стоимость поста
            $100-400.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section id="podkhod" class="section bg-dark">
    <div class="container narrow">
      <Label text="Воронка" />
      <h2>Как строим воронку для проектов в Грузии</h2>

      <div class="grid cols-2">
        <div class="card">
          <h3>Квалификация по цели</h3>
          <p>
            На старте воронки - квиз: «для жизни, инвестиций или сдачи?».
            Под каждую цель - разная воронка. Для релокантов акцент на
            инфраструктуру и быстрое заселение. Для инвесторов - на
            доходность. Для бизнес-эмигрантов - на IP-статус и ВНЖ.
          </p>
        </div>

        <div class="card">
          <h3>ВНЖ и безвизовый режим в хедлайне</h3>
          <p>
            Для русскоязычной аудитории центральный триггер - возможность
            легально жить в Грузии. Реклама не прячет этот мотив, а
            выносит его в первый экран: «купи квартиру и получи ВНЖ».
          </p>
        </div>

        <div class="card">
          <h3>Видео-туры по районам</h3>
          <p>
            Релоканту важна не только квартира, но и район: безопасность,
            инфраструктура, школы, соседи. Снимаем короткие видео-гайды
            по районам Тбилиси и Батуми, раздаем их как лид-магниты.
          </p>
        </div>

        <div class="card">
          <h3>Калькулятор доходности для Батуми</h3>
          <p>
            Для инвестиционных проектов в Батуми - интерактивный
            калькулятор, где покупатель сам подбирает параметры (цена
            объекта, сезонная загрузка, комиссия УК) и видит
            ориентировочную доходность. Это убирает «обещания
            воздушных 15%» и дает честные ожидания.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section id="process" class="section">
    <div class="container narrow">
      <Label text="Процесс" />
      <h2>Как запускаем проект в Грузии</h2>

      <ol class="process-steps">
        <li>
          <strong>Бриф и проверка объекта</strong>
          <div>
            Смотрим проект, документы, цены, районную специфику. В Батуми
            дополнительно проверяем модель управления арендой. В Тбилиси -
            ориентированность проекта на релокантов или локальных.
          </div>
        </li>
        <li>
          <strong>Медиаплан по целям аудитории</strong>
          <div>
            Разбиваем бюджет под три цели: жизнь, инвестиции, гражданство/
            ВНЖ. Даем прогноз по CPL и сделкам в каждом сегменте.
          </div>
        </li>
        <li>
          <strong>Подготовка контента</strong>
          <div>
            Видео-туры по районам, калькулятор доходности (если нужен),
            креативы под три сегмента, посадочная с разбором ВНЖ и
            IP-статуса.
          </div>
        </li>
        <li>
          <strong>Запуск и оптимизация</strong>
          <div>
            Meta + Яндекс + Google + Telegram-посевы. Еженедельные отчеты
            по полной воронке.
          </div>
        </li>
      </ol>
    </div>
  </section>

  <section id="faq" class="section bg-dark">
    <div class="container narrow">
      <Faq tag="georgia" title="Вопросы по рекламе недвижимости в Грузии" label="FAQ" />
    </div>
  </section>

  <StickyMobileCta targetHash="#form-final" label="Обсудить проект" />

  <CtaSection
    title="Обсудим ваш проект в Грузии"
    description="Бесплатная 40-минутная встреча. Разберем объекты или пул, определим целевой сегмент (релоканты, инвесторы, бизнес-эмигранты), посчитаем экономику, покажем медиаплан под выбранный сегмент."
    leadSource="georgia"
    contentCategory="real-estate"
    formTitle="Получить расчет по Грузии"
    bullets={[
      'Разбор по сегментам: жизнь, инвестиции, бизнес-эмиграция',
      'Стратегия ВНЖ и IP-статуса в коммуникации',
      'Медиаплан на 3 месяца с прогнозом по сделкам',
    ]}
  />
</BaseLayout>
