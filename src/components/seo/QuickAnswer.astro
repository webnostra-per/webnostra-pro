---
// QuickAnswer - блок быстрого ответа для LLM и людей
// Ставится первым после Hero на коммерческих страницах
// Формат специально структурирован для экстракции нейросетями

export interface QuickAnswerItem {
  label: string;
  value: string;
}

interface Props {
  title: string;
  summary: string;
  items: QuickAnswerItem[];
  updated?: string; // "Апрель 2026"
  class?: string;
}

const { title, summary, items, updated = "Апрель 2026", class: className = "" } = Astro.props;
---

<aside class={`quick-answer ${className}`} aria-labelledby="quick-answer-title">
  <div class="qa-header">
    <span class="qa-badge">Быстрый ответ</span>
    <span class="qa-updated">Обновлено: {updated}</span>
  </div>
  <h2 id="quick-answer-title" class="qa-title">{title}</h2>
  <p class="qa-summary">{summary}</p>
  <ul class="qa-list">
    {items.map((item) => (
      <li class="qa-item">
        <span class="qa-item-label">{item.label}:</span>
        <span class="qa-item-value">{item.value}</span>
      </li>
    ))}
  </ul>
</aside>

<style>
  .quick-answer {
    background: linear-gradient(135deg, rgba(212, 175, 55, 0.06), rgba(212, 175, 55, 0.02));
    border: 1px solid rgba(212, 175, 55, 0.18);
    border-radius: 16px;
    padding: 1.75rem 2rem;
    margin: 2rem 0;
    max-width: 100%;
  }

  .qa-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .qa-badge {
    display: inline-block;
    background: rgba(212, 175, 55, 0.15);
    color: #d4af37;
    padding: 0.3rem 0.75rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .qa-updated {
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.5);
    font-variant-numeric: tabular-nums;
  }

  .qa-title {
    font-family: 'Unbounded', sans-serif;
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    font-weight: 600;
    color: #fff;
    margin: 0 0 0.75rem 0;
    line-height: 1.3;
  }

  .qa-summary {
    font-size: 1rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.85);
    margin: 0 0 1.25rem 0;
  }

  .qa-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.65rem;
  }

  .qa-item {
    display: flex;
    gap: 0.6rem;
    font-size: 0.95rem;
    line-height: 1.5;
    padding: 0.5rem 0.75rem;
    background: rgba(255, 255, 255, 0.025);
    border-radius: 8px;
    border-left: 2px solid rgba(212, 175, 55, 0.4);
  }

  .qa-item-label {
    color: rgba(255, 255, 255, 0.7);
    min-width: fit-content;
  }

  .qa-item-value {
    color: #fff;
    font-weight: 500;
  }

  @media (max-width: 640px) {
    .quick-answer {
      padding: 1.25rem 1.25rem;
      border-radius: 12px;
    }

    .qa-list {
      gap: 0.5rem;
    }

    .qa-item {
      flex-direction: column;
      gap: 0.15rem;
      padding: 0.6rem 0.75rem;
    }
  }
</style>
