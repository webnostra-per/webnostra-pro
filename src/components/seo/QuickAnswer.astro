---
// QuickAnswer - блок быстрого ответа для LLM и людей
// Ставится первым после Hero на коммерческих страницах
// Формат специально структурирован для экстракции нейросетями

export interface QuickAnswerItem {
  label: string;
  value: string;
}

interface Props {
  title: string;
  summary: string;
  items: QuickAnswerItem[];
  updated?: string; // "Апрель 2026"
  class?: string;
}

const { title, summary, items, updated = "Апрель 2026", class: className = "" } = Astro.props;
---

<section class="quick-answer-section">
  <div class="container narrow">
    <aside class={`quick-answer ${className}`} aria-labelledby="quick-answer-title">
      <div class="qa-header">
        <span class="qa-badge">Быстрый ответ</span>
        <span class="qa-updated">Обновлено: {updated}</span>
      </div>
      <h2 id="quick-answer-title" class="qa-title">{title}</h2>
      <p class="qa-summary">{summary}</p>
      <dl class="qa-list">
        {items.map((item) => (
          <div class="qa-item">
            <dt class="qa-item-label">{item.label}</dt>
            <dd class="qa-item-value">{item.value}</dd>
          </div>
        ))}
      </dl>
    </aside>
  </div>
</section>

<style>
  .quick-answer-section {
    padding: 32px 0 8px;
  }

  .quick-answer {
    background: linear-gradient(135deg, rgba(212, 175, 55, 0.07), rgba(212, 175, 55, 0.015));
    border: 1px solid rgba(212, 175, 55, 0.22);
    border-radius: 16px;
    padding: 28px 32px;
    max-width: 100%;
  }

  .qa-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 18px;
    flex-wrap: wrap;
    gap: 8px;
  }

  .qa-badge {
    display: inline-block;
    background: rgba(212, 175, 55, 0.15);
    color: #d4af37;
    padding: 4px 12px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .qa-updated {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.45);
    font-variant-numeric: tabular-nums;
  }

  .qa-title {
    font-family: 'Unbounded', sans-serif;
    font-size: clamp(18px, 2.2vw, 22px);
    font-weight: 600;
    color: #fff;
    margin: 0 0 12px 0;
    line-height: 1.3;
    letter-spacing: -0.01em;
  }

  .qa-summary {
    font-size: 16px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.82);
    margin: 0 0 20px 0;
  }

  .qa-list {
    margin: 0;
    padding: 0;
    display: grid;
    gap: 8px;
  }

  .qa-item {
    display: grid;
    grid-template-columns: minmax(200px, 260px) 1fr;
    gap: 18px;
    align-items: baseline;
    padding: 12px 16px;
    background: rgba(255, 255, 255, 0.025);
    border-radius: 10px;
    border-left: 2px solid rgba(212, 175, 55, 0.45);
  }

  .qa-item-label {
    margin: 0;
    color: rgba(255, 255, 255, 0.62);
    font-size: 14px;
    font-weight: 400;
    line-height: 1.45;
  }

  .qa-item-value {
    margin: 0;
    color: #fff;
    font-size: 15px;
    font-weight: 500;
    line-height: 1.5;
  }

  @media (max-width: 720px) {
    .quick-answer-section {
      padding: 24px 0 4px;
    }

    .quick-answer {
      padding: 20px 18px;
      border-radius: 14px;
    }

    .qa-item {
      grid-template-columns: 1fr;
      gap: 3px;
      padding: 12px 14px;
    }

    .qa-item-label {
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: rgba(212, 175, 55, 0.75);
    }

    .qa-item-value {
      font-size: 15px;
    }
  }
</style>
