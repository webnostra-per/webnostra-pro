---
/**
 * HeroHome - hero главной страницы.
 * Двухколоночный: слева - позиционирование + метрики + status-pill,
 * справа - форма заявки. По принципу re-thai: минимум трения.
 *
 * v2.29: Новое позиционирование "не агентство, а вовлеченная трафик-команда"
 * + гарантия-блок "Работаем до результата" (вариант В: заголовок + sub).
 *
 * Используется только на index.astro.
 */

import StatusPill from '@components/ui/StatusPill.astro';
import LeadForm from '@components/ui/LeadForm.astro';
import Button from '@components/ui/Button.astro';
---

<section class="hero">
  <div class="container">
    <div class="hero-inner">
      <div class="hero-content">
        <div class="hero-badge">
          <span class="dot" aria-hidden="true"></span>
          5 профильных команд · 200+ проектов · с 2018
        </div>

        <h1>
          <span class="brand">WEBNOSTRA PERFORMANCE</span> - не агентство, а вовлеченная <span class="accent">трафик-команда</span>
        </h1>

        <p class="hero-desc">
          Операционный партнер роста для бизнеса в недвижимости, e-commerce,
          инфобизнесе, туризме и медицине. Пять профильных трафик-команд внутри
          WEBNOSTRA - каждая знает рынок изнутри, работает на квалифицированные
          лиды и оцифрованную продажу.
        </p>

        <div class="hero-guarantee" aria-label="Гарантия результата">
          <svg class="hero-guarantee-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
            <polyline points="9 12 11 14 15 10" />
          </svg>
          <div class="hero-guarantee-body">
            <p class="hero-guarantee-title">Работаем до результата</p>
            <p class="hero-guarantee-sub">Фиксируем KPI в договоре. Не достигли - работаем бесплатно до цели.</p>
          </div>
        </div>

        <div class="hero-ctas">
          <Button href="#cases" variant="secondary" arrow={false}>Смотреть кейсы</Button>
        </div>

        <div class="hero-stats">
          <div class="hero-stat">
            <div class="hero-stat-value">$2.8M</div>
            <div class="hero-stat-label">под управлением</div>
          </div>
          <div class="hero-stat">
            <div class="hero-stat-value">200+</div>
            <div class="hero-stat-label">проектов за 8 лет</div>
          </div>
          <div class="hero-stat">
            <div class="hero-stat-value">x5</div>
            <div class="hero-stat-label">средний ROI</div>
          </div>
        </div>

        <div class="hero-status">
          <StatusPill />
        </div>
      </div>

      <div class="hero-visual" id="form">
        <LeadForm
          id="leadFormHero"
          leadSource="homepage"
          contentCategory="general"
          title="Обсудить проект"
          subtitle="Покажем кейсы, разберем кабинеты, дадим прогноз - ответим за 24 часа"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: calc(100vh - 68px);
    padding: 60px 0 80px;
    position: relative;
    display: flex;
    align-items: center;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    top: -10%; right: -15%;
    width: 700px; height: 700px;
    background: radial-gradient(circle, rgba(201, 168, 76, 0.08), transparent 70%);
    pointer-events: none;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 64px;
    align-items: center;
    position: relative;
    z-index: 1;
    width: 100%;
  }

  .hero-content { max-width: 620px; }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--gold-dim);
    border: 1px solid rgba(201, 168, 76, 0.25);
    padding: 6px 16px;
    border-radius: 100px;
    margin-bottom: 28px;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--gold);
    letter-spacing: 0.02em;
  }
  .hero-badge .dot {
    width: 6px; height: 6px;
    background: var(--gold);
    border-radius: 50%;
    animation: heroPulse 2s infinite;
  }
  @keyframes heroPulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .hero h1 {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 5vw, 3.4rem);
    font-weight: 600;
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin-bottom: 20px;
  }

  .hero h1 .brand {
    display: inline;
    color: #ffffff;
    letter-spacing: 0;
  }

  .hero-desc {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--text-dim);
    max-width: 520px;
    margin-bottom: 28px;
  }

  .hero-guarantee {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 14px 18px 14px 16px;
    background: rgba(201, 168, 76, 0.05);
    border-left: 2px solid var(--gold);
    border-radius: 0 8px 8px 0;
    margin-bottom: 32px;
    max-width: 520px;
  }

  .hero-guarantee-icon {
    flex-shrink: 0;
    color: var(--gold);
    margin-top: 2px;
  }

  .hero-guarantee-body {
    min-width: 0;
  }

  .hero-guarantee-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text, #ffffff);
    margin: 0 0 4px;
    line-height: 1.3;
  }

  .hero-guarantee-sub {
    font-size: 0.82rem;
    color: var(--text-dim);
    margin: 0;
    line-height: 1.5;
  }

  .hero-ctas {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    margin-bottom: 48px;
  }

  .hero-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
  }
  .hero-stat {
    padding: 20px 0;
    border-top: 1px solid var(--border);
  }
  .hero-stat:not(:last-child) { border-right: 1px solid var(--border); padding-right: 20px; }
  .hero-stat:not(:first-child) { padding-left: 20px; }
  .hero-stat-value {
    font-family: var(--font-display);
    font-size: 1.7rem;
    font-weight: 700;
    color: var(--gold);
    margin-bottom: 4px;
    line-height: 1;
  }
  .hero-stat-label {
    font-size: 0.72rem;
    color: var(--text-dim);
    letter-spacing: 0.02em;
  }

  .hero-status {
    margin-top: 32px;
  }

  .hero-visual {
    width: 100%;
    max-width: 480px;
    justify-self: end;
    align-self: start;
    margin-top: 12px;
  }

  /* Mobile */
  @media (max-width: 1024px) {
    .hero-inner { grid-template-columns: 1fr; gap: 40px; }
    .hero-visual { max-width: 100%; justify-self: stretch; }
    .hero-guarantee { max-width: none; }
  }
  @media (max-width: 640px) {
    .hero { padding: 40px 0 60px; min-height: auto; }
    .hero-guarantee {
      padding: 12px 14px;
    }
    .hero-guarantee-title {
      font-size: 0.9rem;
    }
    .hero-guarantee-sub {
      font-size: 0.78rem;
    }
    .hero-stats { grid-template-columns: 1fr; gap: 0; }
    .hero-stat { padding: 16px 0 !important; border-right: none !important; border-top: 1px solid var(--border); }
    .hero-stat:last-child { border-bottom: 1px solid var(--border); }
    .hero-stat-value { font-size: 1.5rem; }
  }
</style>
