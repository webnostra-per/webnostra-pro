---
/**
 * LeadForm - форма заявки.
 * Логика отправки - в src/lib/leads.ts, инициализация - в BaseLayout.astro.
 *
 * Пропсы:
 *   leadSource - ключ из LEAD_SOURCE_LABELS (напр. 'homepage', 'thailand')
 *   contentCategory - для Meta Pixel content_category
 *   title - заголовок формы (default: 'Обсудить проект')
 *   subtitle - подзаголовок (default: 'Ответим в течение 24 часов')
 *   submitLabel - текст кнопки (default: 'Отправить заявку')
 *   note - нижний disclaimer (default: 'Без спама...')
 *   compact - версия без заголовка (для компактных мест)
 *   id - уникальный id для data-group chips (обязателен если на странице несколько форм)
 */

interface Props {
  leadSource: string;
  contentCategory?: string;
  title?: string;
  subtitle?: string;
  submitLabel?: string;
  note?: string;
  compact?: boolean;
  id?: string;
}

const {
  leadSource,
  contentCategory = 'general',
  title = 'Обсудить проект',
  subtitle = 'Покажем кейсы, разберем кабинеты, дадим прогноз - ответим за 24 часа',
  submitLabel = 'Отправить заявку',
  note = 'Без спама. Не передаем контакты третьим лицам.',
  compact = false,
  id = 'lead-form',
} = Astro.props;

const chipsGroupId = `${id}-chips`;
const successId = `${id}-success`;
---

<form class="form-card" id={id} data-lead-source={leadSource} data-content-category={contentCategory}>
  {!compact && (
    <div class="form-head">
      <div class="form-title">{title}</div>
      <div class="form-sub">{subtitle}</div>
    </div>
  )}

  <div class="form-row">
    <label class="form-label" for={`${id}-name`}>Имя</label>
    <input
      type="text" id={`${id}-name`} name="name"
      class="form-input"
      placeholder="Как вас зовут"
      autocomplete="name"
      required
    />
  </div>

  <div class="form-row">
    <label class="form-label" for={`${id}-contact`}>Telegram или телефон</label>
    <input
      type="text" id={`${id}-contact`} name="contact"
      class="form-input"
      placeholder="@magosh или +66 8..."
      autocomplete="tel"
      required
    />
  </div>

  <div class="form-row">
    <label class="form-label">
      Рынок <span class="form-optional">- опционально</span>
    </label>
    <div class="form-chips" data-group={chipsGroupId}>
      <button type="button" class="chip active" data-value="RU">Русский</button>
      <button type="button" class="chip" data-value="EN">Английский</button>
      <button type="button" class="chip" data-value="MIX">Микс</button>
      <button type="button" class="chip" data-value="PL">Другой</button>
    </div>
    <input type="hidden" name="market" id={chipsGroupId} value="RU" />
  </div>

  <div class="form-consent">
    <input
      type="checkbox"
      id={`${id}-consent`}
      name="consent"
      class="form-consent-input"
      checked
      required
    />
    <label for={`${id}-consent`} class="form-consent-label">
      Согласен с <a href="/privacy/" target="_blank" rel="noopener">политикой конфиденциальности</a> и обработкой персональных данных
    </label>
  </div>

  <button type="submit" class="form-submit">
    {submitLabel}
    <span class="arrow">→</span>
  </button>

  <div class="form-note">{note}</div>

  <div class="form-success" id={successId}>
    <div class="form-success-icon">✓</div>
    <div class="form-success-t">Получили заявку!</div>
    <div class="form-success-s">
      Вернемся в течение 24 часов в Telegram или по номеру, который указали.
    </div>
  </div>
</form>

<style>
  .form-card {
    background: var(--bg-card);
    border: 1px solid var(--border-2);
    border-radius: var(--radius-lg);
    padding: 28px;
    position: relative;
    overflow: hidden;
  }
  /* Золотая линия сверху - акцент */
  .form-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
    opacity: 0.5;
  }

  .form-head { margin-bottom: 24px; }
  .form-title {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 600;
    letter-spacing: -0.03em;
    margin-bottom: 6px;
  }
  .form-sub {
    font-size: 0.85rem;
    color: var(--text-dim);
    line-height: 1.5;
  }

  .form-row { margin-bottom: 18px; }
  .form-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 8px;
    font-weight: 500;
  }
  .form-optional {
    text-transform: none;
    letter-spacing: 0;
    color: var(--text-muted);
    font-weight: 400;
  }
  .form-input {
    width: 100%;
    min-height: 48px; /* iOS safe: больше 44px */
    background: var(--surface);
    border: 1px solid var(--border-2);
    border-radius: var(--radius-sm);
    padding: 12px 14px;
    color: var(--text);
    font-size: 0.95rem;
    transition: border-color 0.2s;
  }
  .form-input::placeholder { color: var(--text-muted); }
  .form-input:focus {
    outline: none;
    border-color: var(--gold);
  }

  /* Chips */
  .form-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .chip {
    background: var(--surface);
    border: 1px solid var(--border-2);
    border-radius: var(--radius-sm);
    padding: 10px 14px;
    font-size: 0.85rem;
    color: var(--text-dim);
    cursor: pointer;
    transition: all 0.2s;
    min-height: 40px;
    flex: 1 1 calc(50% - 4px);
  }
  .chip:hover { border-color: var(--gold); color: var(--text); }
  .chip.active {
    background: var(--gold);
    border-color: var(--gold);
    color: var(--bg);
    font-weight: 600;
  }

  /* Consent checkbox */
  .form-consent {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    margin-top: 4px;
    margin-bottom: 14px;
  }
  .form-consent-input {
    flex-shrink: 0;
    width: 18px;
    height: 18px;
    margin-top: 2px;
    accent-color: var(--gold);
    cursor: pointer;
  }
  .form-consent-label {
    font-size: 0.78rem;
    color: var(--text-dim);
    line-height: 1.5;
    cursor: pointer;
    user-select: none;
  }
  .form-consent-label a {
    color: var(--gold);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .form-consent-label a:hover {
    color: var(--gold-light);
  }

  /* Submit */
  .form-submit {
    width: 100%;
    min-height: 52px;
    background: var(--gold);
    color: var(--bg);
    border: none;
    border-radius: var(--radius-sm);
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    transition: all 0.2s;
    margin-top: 6px;
  }
  .form-submit:hover:not(:disabled) {
    background: var(--gold-light);
    transform: translateY(-1px);
  }
  .form-submit:disabled { cursor: not-allowed; }
  .form-submit .arrow { font-size: 1.15em; }

  .form-note {
    margin-top: 12px;
    font-size: 0.75rem;
    color: var(--text-muted);
    text-align: center;
    line-height: 1.5;
  }

  /* Success state */
  .form-success {
    display: none;
    text-align: center;
    padding: 24px 0;
  }
  .form-success.show { display: block; }
  .form-success-icon {
    width: 56px; height: 56px;
    background: var(--gold-dim);
    border: 2px solid var(--gold);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.6rem; color: var(--gold);
    margin: 0 auto 16px;
    font-weight: 600;
  }
  .form-success-t {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 600;
    margin-bottom: 8px;
  }
  .form-success-s {
    font-size: 0.88rem;
    color: var(--text-dim);
    line-height: 1.6;
    max-width: 300px;
    margin: 0 auto;
  }
</style>

<script>
  // Подключаем форму к logic из lib/leads.ts (submitForm регистрируется в window через initLeadSystem)
  // Используем dataset для получения leadSource и contentCategory - это делает компонент полностью декларативным.
  document.querySelectorAll<HTMLFormElement>('form.form-card').forEach(form => {
    form.addEventListener('submit', (e) => {
      const leadSource = form.dataset.leadSource || 'unknown';
      const contentCategory = form.dataset.contentCategory || 'general';
      const submitFn = (window as any).submitForm;
      if (typeof submitFn === 'function') {
        submitFn(e, leadSource, contentCategory);
      } else {
        console.error('submitForm not registered - initLeadSystem() not called?');
        e.preventDefault();
      }
    });
  });
</script>
