---
/**
 * LeadPopup - глобальная модалка с формой.
 * Монтируется один раз в BaseLayout.astro.
 * Открывается:
 *   - программно через window.openLeadPopup()
 *   - клик по любому элементу с data-open-lead-popup
 *   - клик на href="#form-final" если на странице НЕТ такого блока (логика в BaseLayout)
 * Закрывается:
 *   - Esc
 *   - клик по overlay
 *   - крестик
 * При открытии - блокирует скролл body через body.popup-open.
 */

import LeadForm from './LeadForm.astro';
---

<div id="leadPopup" class="lead-popup" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="leadPopupTitle">
  <div class="lead-popup-overlay" data-close-popup></div>
  <div class="lead-popup-content" role="document">
    <button type="button" class="lead-popup-close" aria-label="Закрыть" data-close-popup>
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <path d="M5 5L15 15M15 5L5 15" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
      </svg>
    </button>
    <h2 id="leadPopupTitle" class="visually-hidden">Обсудить проект</h2>
    <LeadForm
      leadSource="header-popup"
      contentCategory="general"
      title="Обсудить проект"
      subtitle="Оставьте контакты - вернемся в течение 24 часов с аудитом и прогнозом"
      id="lead-popup-form"
    />
  </div>
</div>

<style>
  .lead-popup {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 24px;
  }
  .lead-popup.open {
    display: flex;
    animation: popupFadeIn 0.2s ease-out;
  }

  .lead-popup-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.75);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    cursor: pointer;
  }

  .lead-popup-content {
    position: relative;
    width: 100%;
    max-width: 460px;
    max-height: calc(100vh - 48px);
    overflow-y: auto;
    overscroll-behavior: contain;
    animation: popupSlideUp 0.25s ease-out;
  }

  .lead-popup-content :global(.form-card) {
    margin: 0;
  }

  .lead-popup-close {
    position: absolute;
    top: 14px;
    right: 14px;
    z-index: 2;
    width: 34px;
    height: 34px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--border-2);
    border-radius: 50%;
    color: var(--text-dim);
    cursor: pointer;
    transition: all 0.2s;
  }
  .lead-popup-close:hover {
    background: var(--gold);
    color: var(--bg);
    border-color: var(--gold);
  }

  .visually-hidden {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @keyframes popupFadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  @keyframes popupSlideUp {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  :global(body.popup-open) {
    overflow: hidden;
  }

  @media (max-width: 600px) {
    .lead-popup {
      padding: 12px;
      align-items: flex-start;
      padding-top: 48px;
    }
    .lead-popup-content {
      max-height: calc(100vh - 60px);
    }
  }
</style>

<script>
  (function initLeadPopup() {
    const popup = document.getElementById('leadPopup');
    if (!popup) return;

    const body = document.body;
    let lastFocused: HTMLElement | null = null;

    function openPopup() {
      lastFocused = document.activeElement as HTMLElement;
      popup?.classList.add('open');
      popup?.setAttribute('aria-hidden', 'false');
      body.classList.add('popup-open');
      setTimeout(() => {
        const nameInput = popup?.querySelector<HTMLInputElement>('input[name="name"]');
        nameInput?.focus();
      }, 50);
    }

    function closePopup() {
      popup?.classList.remove('open');
      popup?.setAttribute('aria-hidden', 'true');
      body.classList.remove('popup-open');
      if (lastFocused && typeof lastFocused.focus === 'function') {
        lastFocused.focus();
      }
    }

    (window as any).openLeadPopup = openPopup;
    (window as any).closeLeadPopup = closePopup;

    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      const trigger = target.closest('[data-open-lead-popup]');
      if (trigger) {
        e.preventDefault();
        openPopup();
      }
    });

    popup.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target.closest('[data-close-popup]')) {
        e.preventDefault();
        closePopup();
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && popup.classList.contains('open')) {
        closePopup();
      }
    });
  })();
</script>
