---
/**
 * Navigation - фиксированная шапка сайта.
 * Три пункта с dropdown (Услуги / Недвижимость / Отрасли).
 * Desktop: hover-based (CSS only).
 * Mobile: accordion через checkbox.
 *
 * Пропсы: нет (данные для dropdown берутся из content collections).
 */
import { getCollection } from 'astro:content';

// Данные для dropdown. Сортируем по order.
const services = (await getCollection('services')).map(s => s.data).sort((a, b) => a.order - b.order);
const geos = (await getCollection('geos')).map(g => g.data).sort((a, b) => a.order - b.order);
const industries = (await getCollection('industries')).map(i => i.data).sort((a, b) => a.order - b.order);
---

<nav id="nav" class="nav">
  <div class="nav-inner">
    <a href="/" class="logo" aria-label="WEBNOSTRA - на главную">
      <div class="logo-mark">W</div>
      <div class="logo-text">WEBNOSTRA<span>PERFORMANCE</span></div>
    </a>

    <!-- Desktop nav -->
    <ul class="nav-menu" role="menubar">
      <li class="nav-item nav-item-dropdown">
        <a href="/services/" role="menuitem">Услуги</a>
        <div class="nav-dropdown">
          {services.map(svc => (
            <a href={`/services/${svc.id}/`} class="nav-dropdown-item">
              <span class="nav-dropdown-title">{svc.title}</span>
              <span class="nav-dropdown-desc">{svc.shortDescription}</span>
            </a>
          ))}
        </div>
      </li>

      <li class="nav-item nav-item-dropdown">
        <a href="/real-estate/" role="menuitem">Недвижимость</a>
        <div class="nav-dropdown">
          {geos.map(geo => (
            <a href={`/real-estate/${geo.id}/`} class="nav-dropdown-item">
              <span class="nav-dropdown-title">{geo.flag} {geo.title}</span>
              <span class="nav-dropdown-desc">{geo.shortDescription}</span>
            </a>
          ))}
        </div>
      </li>

      <li class="nav-item nav-item-dropdown align-right">
        <a href="/industries/" role="menuitem">Отрасли</a>
        <div class="nav-dropdown">
          {industries.map(ind => (
            <a href={`/industries/${ind.id}/`} class="nav-dropdown-item">
              <span class="nav-dropdown-title">{ind.title}</span>
              <span class="nav-dropdown-desc">{ind.shortDescription}</span>
            </a>
          ))}
        </div>
      </li>

      <li class="nav-item">
        <a href="/portfolio/" role="menuitem">Кейсы</a>
      </li>

      <li class="nav-item">
        <a href="/about/" role="menuitem">О нас</a>
      </li>
    </ul>

    <a href="#form-final" class="nav-cta">Обсудить проект</a>

    <!-- Mobile menu toggle -->
    <input type="checkbox" id="menuToggle" class="menu-toggle-input" />
    <label for="menuToggle" class="menu-toggle" aria-label="Открыть меню">
      <span></span>
      <span></span>
      <span></span>
    </label>

    <!-- Mobile menu -->
    <div class="mobile-menu">
      <details class="mobile-group">
        <summary>Услуги</summary>
        <a href="/services/">Все услуги</a>
        {services.map(svc => (
          <a href={`/services/${svc.id}/`}>{svc.title}</a>
        ))}
      </details>
      <details class="mobile-group">
        <summary>Недвижимость</summary>
        <a href="/real-estate/">Все страны</a>
        {geos.map(geo => (
          <a href={`/real-estate/${geo.id}/`}>{geo.flag} {geo.title}</a>
        ))}
      </details>
      <details class="mobile-group">
        <summary>Отрасли</summary>
        <a href="/industries/">Все отрасли</a>
        {industries.map(ind => (
          <a href={`/industries/${ind.id}/`}>{ind.title}</a>
        ))}
      </details>
      <a href="/portfolio/" class="mobile-link">Кейсы</a>
      <a href="/about/" class="mobile-link">О нас</a>
      <a href="/contacts/" class="mobile-link">Контакты</a>
      <a href="#form-final" class="mobile-cta">Обсудить проект →</a>
    </div>
  </div>
</nav>

<style>
  .nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    background: rgba(10, 10, 15, 0.75);
    backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid transparent;
    transition: background 0.3s, border-color 0.3s;
  }
  .nav.scrolled {
    background: rgba(10, 10, 15, 0.92);
    border-bottom-color: var(--border);
  }
  .nav-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 14px 24px;
    display: flex; align-items: center; gap: 24px;
    position: relative;
  }

  /* Logo */
  .logo {
    display: flex; align-items: center; gap: 10px;
    text-decoration: none; color: var(--text);
    font-weight: 700; flex-shrink: 0;
  }
  .logo-mark {
    width: 34px; height: 34px;
    background: var(--gold);
    border-radius: 6px;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-display);
    font-weight: 700; font-size: 1.05rem;
    color: var(--bg);
  }
  .logo-text {
    font-family: var(--font-display);
    font-size: 0.88rem; font-weight: 600;
    letter-spacing: 0.02em; line-height: 1;
    display: flex; flex-direction: column; gap: 2px;
  }
  .logo-text span {
    font-family: var(--font-mono);
    font-size: 0.58rem; font-weight: 400;
    color: var(--text-dim); letter-spacing: 0.1em;
  }

  /* Desktop menu */
  .nav-menu {
    display: flex; align-items: center; gap: 2px;
    list-style: none; padding: 0; margin: 0;
    flex: 1; justify-content: center;
  }
  .nav-item { position: relative; }
  .nav-item > a {
    display: block;
    padding: 10px 14px;
    font-size: 0.88rem;
    color: var(--text-dim);
    text-decoration: none;
    transition: color 0.2s;
    border-radius: 6px;
  }
  .nav-item > a:hover { color: var(--text); }

  /* Dropdown */
  .nav-item-dropdown > a::after {
    content: '▾';
    margin-left: 4px;
    font-size: 0.7em;
    color: var(--text-muted);
    transition: transform 0.2s;
  }
  .nav-item-dropdown:hover > a::after { transform: rotate(180deg); }
  .nav-dropdown {
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    width: 360px;
    max-height: calc(100vh - 100px);
    overflow-y: auto;
    overscroll-behavior: contain;
    background: var(--bg-card);
    border: 1px solid var(--border-2);
    border-radius: var(--radius);
    padding: 6px;
    opacity: 0; visibility: hidden;
    transform: translateY(-6px);
    transition: opacity 0.2s, transform 0.2s, visibility 0.2s;
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.4);
  }
  /* Тонкий скроллбар у dropdown когда не помещается */
  .nav-dropdown::-webkit-scrollbar { width: 6px; }
  .nav-dropdown::-webkit-scrollbar-track { background: transparent; }
  .nav-dropdown::-webkit-scrollbar-thumb {
    background: rgba(201, 168, 76, 0.2);
    border-radius: 3px;
  }
  .nav-dropdown::-webkit-scrollbar-thumb:hover {
    background: rgba(201, 168, 76, 0.35);
  }

  /* Dropdown для пункта "Отрасли" прижимаем по правому краю — он ближе всего к правому краю меню */
  .nav-item-dropdown.align-right > .nav-dropdown {
    left: auto; right: 0;
  }

  .nav-item-dropdown:hover .nav-dropdown,
  .nav-item-dropdown:focus-within .nav-dropdown {
    opacity: 1; visibility: visible;
    transform: translateY(0);
  }
  .nav-dropdown-item {
    display: flex; flex-direction: column; gap: 2px;
    padding: 9px 12px;
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: background 0.15s;
  }
  .nav-dropdown-item:hover { background: var(--surface); }
  .nav-dropdown-title {
    font-size: 0.88rem; font-weight: 600;
    color: var(--text);
    line-height: 1.3;
  }
  .nav-dropdown-desc {
    font-size: 0.74rem;
    color: var(--text-dim);
    line-height: 1.4;
    /* Ограничиваем до 2 строк, лишнее с многоточием */
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* CTA */
  .nav-cta {
    display: inline-flex; align-items: center; gap: 6px;
    background: var(--gold); color: var(--bg);
    padding: 10px 18px; border-radius: var(--radius-sm);
    font-size: 0.85rem; font-weight: 600;
    text-decoration: none;
    transition: background 0.2s;
    flex-shrink: 0;
  }
  .nav-cta:hover { background: var(--gold-light); }

  /* Mobile toggle (hidden on desktop) */
  .menu-toggle-input { display: none; }
  .menu-toggle {
    display: none;
    width: 32px; height: 32px;
    flex-direction: column; justify-content: center; gap: 5px;
    cursor: pointer;
  }
  .menu-toggle span {
    display: block;
    width: 22px; height: 2px;
    background: var(--text);
    border-radius: 2px;
    transition: all 0.25s;
  }

  /* Mobile menu (hidden on desktop) */
  .mobile-menu { display: none; }

  /* ── Mobile breakpoint ── */
  @media (max-width: 1024px) {
    .nav-menu, .nav-cta { display: none; }
    .menu-toggle { display: flex; }

    .mobile-menu {
      display: block;
      position: fixed;
      top: 68px; left: 0; right: 0;
      max-height: calc(100vh - 68px);
      background: var(--bg);
      border-top: 1px solid var(--border);
      padding: 16px 24px 40px;
      overflow-y: auto;
      transform: translateY(-100%);
      opacity: 0; visibility: hidden;
      transition: all 0.3s;
    }
    .menu-toggle-input:checked ~ .mobile-menu {
      transform: translateY(0); opacity: 1; visibility: visible;
    }
    .menu-toggle-input:checked ~ .menu-toggle span:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
    }
    .menu-toggle-input:checked ~ .menu-toggle span:nth-child(2) { opacity: 0; }
    .menu-toggle-input:checked ~ .menu-toggle span:nth-child(3) {
      transform: translateY(-7px) rotate(-45deg);
    }

    .mobile-group { padding: 12px 0; border-bottom: 1px solid var(--border); }
    .mobile-group summary {
      font-family: var(--font-display);
      font-size: 1.1rem; font-weight: 600;
      padding: 6px 0;
      cursor: pointer;
      list-style: none;
      display: flex; justify-content: space-between; align-items: center;
    }
    .mobile-group summary::-webkit-details-marker { display: none; }
    .mobile-group summary::after {
      content: '+'; color: var(--gold); font-size: 1.4rem; font-weight: 400;
      transition: transform 0.2s;
    }
    .mobile-group[open] summary::after { transform: rotate(45deg); }
    .mobile-group a {
      display: block;
      padding: 8px 0 8px 12px;
      font-size: 0.95rem;
      color: var(--text-dim);
      text-decoration: none;
    }
    .mobile-group a:hover { color: var(--gold); }

    .mobile-link {
      display: block;
      padding: 14px 0;
      font-family: var(--font-display);
      font-size: 1.1rem; font-weight: 600;
      color: var(--text);
      border-bottom: 1px solid var(--border);
      text-decoration: none;
    }
    .mobile-cta {
      display: block;
      margin-top: 20px;
      padding: 14px;
      background: var(--gold); color: var(--bg);
      text-align: center;
      border-radius: var(--radius-sm);
      font-weight: 600;
      text-decoration: none;
    }
  }
</style>

<script>
  // Nav scroll effect
  (function initNavScroll() {
    const nav = document.getElementById('nav');
    if (!nav) return;
    const onScroll = () => {
      if (window.scrollY > 20) nav.classList.add('scrolled');
      else nav.classList.remove('scrolled');
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  })();

  // Close mobile menu on anchor click
  document.querySelectorAll<HTMLAnchorElement>('.mobile-menu a').forEach(link => {
    link.addEventListener('click', () => {
      const toggle = document.getElementById('menuToggle') as HTMLInputElement | null;
      if (toggle) toggle.checked = false;
    });
  });
</script>
