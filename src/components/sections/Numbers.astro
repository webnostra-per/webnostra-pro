---
/**
 * Numbers — сетка крупных чисел для быстрого впечатления масштаба.
 * 4 карточки на десктопе — золотое число + описание.
 */

interface NumberItem {
  value: string;
  label: string;
  description?: string;   // опциональная строка под label
}

interface Props {
  label?: string;
  title: string;
  subtitle?: string;
  items: NumberItem[];
}

const { label = 'Цифры', title, subtitle, items } = Astro.props;
---

<section class="numbers section">
  <div class="container">
    <div class="label">{label}</div>
    <h2 class="section-title fade-up" set:html={title} />
    {subtitle && <p class="section-subtitle">{subtitle}</p>}

    <div class="numbers-grid fade-up">
      {items.map(n => (
        <div class="num-card">
          <div class="num-val">{n.value}</div>
          <div class="num-label">{n.label}</div>
          {n.description && <div class="num-desc">{n.description}</div>}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .numbers-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-top: 48px;
  }

  .num-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 32px 24px;
    transition: border-color 0.2s;
  }
  .num-card:hover { border-color: rgba(201, 168, 76, 0.2); }

  .num-val {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 3vw, 2.4rem);
    font-weight: 700;
    color: var(--gold);
    line-height: 1;
    margin-bottom: 12px;
    letter-spacing: -0.03em;
  }
  .num-label {
    font-size: 0.9rem;
    color: var(--text);
    font-weight: 600;
    margin-bottom: 4px;
  }
  .num-desc {
    font-size: 0.78rem;
    color: var(--text-dim);
    line-height: 1.5;
  }

  @media (max-width: 900px) {
    .numbers-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .numbers-grid { grid-template-columns: 1fr; }
  }
</style>
