---
/**
 * RelatedPosts - блок «другие статьи» для страницы блог-поста.
 *
 * Логика рекомендаций:
 *   1. Исключаем текущий пост по excludeSlug.
 *   2. Сначала берём посты с пересечением тегов (по убыванию количества совпадений).
 *   3. Если набралось меньше limit — досыпаем свежими постами по дате.
 *   4. limit = 3 по умолчанию.
 *
 * Пропсы:
 *   excludeSlug — slug текущего поста (обязательно)
 *   tags        — теги текущего поста, массив строк
 *   limit       — сколько постов показать (по умолчанию 3)
 *   title       — заголовок блока (по умолчанию «Читайте также»)
 */

import { getCollection, type CollectionEntry } from 'astro:content';

interface Props {
  excludeSlug: string;
  tags?: string[];
  limit?: number;
  title?: string;
}

const { excludeSlug, tags = [], limit = 3, title = 'Читайте также' } = Astro.props;

// Все опубликованные посты, кроме текущего
let posts = (await getCollection('blog', (e) => e.data.draft !== true))
  .filter((p) => p.id !== excludeSlug);

// Сортировка: сначала по количеству совпадающих тегов, потом по дате
type ScoredPost = { post: CollectionEntry<'blog'>; score: number; ts: number };
const scored: ScoredPost[] = posts.map((p) => {
  const postTags = p.data.tags ?? [];
  const matches = tags.filter((t) => postTags.includes(t)).length;
  const d = p.data.publishedAt instanceof Date ? p.data.publishedAt : new Date(p.data.publishedAt);
  return { post: p, score: matches, ts: d.getTime() };
});

scored.sort((a, b) => {
  if (b.score !== a.score) return b.score - a.score;
  return b.ts - a.ts;
});

const related = scored.slice(0, limit).map((s) => s.post);

// Форматирование даты
const months = ['янв', 'фев', 'мар', 'апр', 'мая', 'июн', 'июл', 'авг', 'сен', 'окт', 'ноя', 'дек'];
function formatShort(d: Date | string) {
  const date = d instanceof Date ? d : new Date(d);
  return `${date.getDate()} ${months[date.getMonth()]} ${date.getFullYear()}`;
}
---

{related.length > 0 && (
  <section class="related-posts section">
    <div class="container narrow">
      <h2 class="related-posts-title">{title}</h2>

      <div class="related-posts-grid">
        {related.map((post) => {
          const firstTag = post.data.tags?.[0];
          return (
            <a class="related-post-card" href={`/blog/${post.id}/`}>
              <div class="related-post-meta">
                <span class="related-post-date">{formatShort(post.data.publishedAt)}</span>
                {firstTag && <span class="related-post-tag">{firstTag}</span>}
              </div>
              <h3 class="related-post-title">{post.data.title}</h3>
              <p class="related-post-description">{post.data.description}</p>
              <div class="related-post-cta">
                Читать статью
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M5 12h14M13 5l7 7-7 7" />
                </svg>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>
)}

<style>
  .related-posts {
    padding: 3rem 0 2rem;
  }

  .related-posts-title {
    font-family: 'Unbounded', sans-serif;
    font-size: clamp(1.4rem, 3vw, 1.85rem);
    font-weight: 600;
    color: #fff;
    margin: 0 0 1.5rem;
  }

  .related-posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .related-post-card {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    padding: 1.5rem;
    background: rgba(255, 255, 255, 0.025);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    text-decoration: none;
    color: inherit;
    transition: all 0.2s ease;
  }

  .related-post-card:hover {
    border-color: rgba(212, 175, 55, 0.4);
    transform: translateY(-2px);
    background: rgba(212, 175, 55, 0.04);
  }

  .related-post-meta {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    font-size: 0.78rem;
  }

  .related-post-date {
    color: rgba(255, 255, 255, 0.5);
  }

  .related-post-tag {
    padding: 2px 10px;
    background: rgba(212, 175, 55, 0.12);
    color: #d4af37;
    border-radius: 999px;
    font-size: 0.72rem;
    letter-spacing: 0.02em;
  }

  .related-post-title {
    font-family: 'Unbounded', sans-serif;
    font-size: 1.05rem;
    font-weight: 600;
    color: #fff;
    line-height: 1.35;
    margin: 0;
  }

  .related-post-description {
    font-size: 0.92rem;
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.65);
    margin: 0;
    flex-grow: 1;
  }

  .related-post-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: #d4af37;
    font-size: 0.88rem;
    font-weight: 500;
    margin-top: 0.25rem;
  }

  @media (max-width: 900px) {
    .related-posts-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
