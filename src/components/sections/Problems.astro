---
/**
 * Problems — блок болей аудитории.
 * 3-6 карточек без решения внутри (решение — вся остальная страница).
 * Красный акцент. Применяется на главной и страницах ниш для прогрева.
 */

interface Problem {
  title: string;
  description: string;
}

interface Props {
  label?: string;
  title: string;          // support <span class="accent">
  subtitle?: string;
  items: Problem[];
}

const {
  label = 'Боли клиентов',
  title,
  subtitle,
  items,
} = Astro.props;
---

<section class="problems section">
  <div class="container">
    <div class="label">{label}</div>
    <h2 class="section-title fade-up" set:html={title} />
    {subtitle && <p class="section-subtitle">{subtitle}</p>}

    <div class="problems-grid">
      {items.map(p => (
        <div class="problem-card fade-up">
          <div class="problem-icon" aria-hidden="true">⚠</div>
          <h3 class="problem-title">{p.title}</h3>
          <p class="problem-desc">{p.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .problems-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 48px;
  }

  .problem-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 28px;
    transition: border-color 0.2s;
  }
  .problem-card:hover { border-color: rgba(231, 76, 60, 0.25); }

  .problem-icon {
    width: 40px; height: 40px;
    background: rgba(231, 76, 60, 0.1);
    border: 1px solid rgba(231, 76, 60, 0.2);
    border-radius: var(--radius-sm);
    display: flex; align-items: center; justify-content: center;
    color: var(--red);
    font-size: 1.2rem;
    margin-bottom: 18px;
  }

  .problem-title {
    font-family: var(--font-body);
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 10px;
    color: var(--text);
    letter-spacing: 0;
  }
  .problem-desc {
    font-size: 0.9rem;
    color: var(--text-dim);
    line-height: 1.65;
  }

  @media (max-width: 900px) {
    .problems-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 560px) {
    .problems-grid { grid-template-columns: 1fr; }
  }
</style>
