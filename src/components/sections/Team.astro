---
/**
 * Team v3 - команда WEBNOSTRA PERFORMANCE.
 *
 * Структура:
 * - Lead (приоритетная карточка, обычно Магош) - на всю ширину,
 *   фото слева, текст справа, статы снизу.
 * - Members (остальные) - три равные карточки в ряд на десктопе,
 *   2+1 на планшете, в столбик на мобильном.
 *
 * Распределение:
 * - Lead = первый по order у кого isLead=true (или первый со stats).
 * - Members = все остальные, сортировка по order.
 *
 * Поле avatar в team.json:
 *   - "M", "+8" и т.п. - буква в кружке
 *   - "/team/magosh.jpg" - картинка через <img>
 */

import { getCollection } from 'astro:content';

interface Props {
  label?: string;
  title: string;
  subtitle?: string;
}

const { label = 'Команда', title, subtitle } = Astro.props;

const team = (await getCollection('team'))
  .map(t => t.data)
  .sort((a, b) => a.order - b.order);

// Lead - первый со stats (обычно Магош).
// Если ни у кого нет stats - первый из массива.
const lead = team.find(m => m.stats && m.stats.length > 0) ?? team[0];
const members = team.filter(m => m.id !== lead?.id);

function isImagePath(v: string): boolean {
  if (!v) return false;
  return v.startsWith('/') || v.startsWith('http') || /\.(jpg|jpeg|png|webp|gif|svg)$/i.test(v);
}
---

<section class="team section">
  <div class="container">
    <div class="label">{label}</div>
    <h2 class="section-title fade-up" set:html={title} />
    {subtitle && <p class="section-subtitle">{subtitle}</p>}

    {lead && (
      <article class="lead-card fade-up">
        <div class="lead-avatar">
          {isImagePath(lead.avatar) ? (
            <img src={lead.avatar} alt={lead.name} loading="lazy" />
          ) : (
            <span class="avatar-letter avatar-letter--lg">{lead.avatar}</span>
          )}
        </div>

        <div class="lead-content">
          <header class="lead-header">
            <div>
              <h3 class="lead-name">{lead.name}</h3>
              <div class="lead-role">{lead.roleFull || lead.role}</div>
            </div>
            {lead.social && (
              <div class="lead-social">
                {lead.social.telegram && (
                  <a href={lead.social.telegram} target="_blank" rel="noopener" class="social-pill">Telegram</a>
                )}
                {lead.social.instagram && (
                  <a href={lead.social.instagram} target="_blank" rel="noopener" class="social-pill">Instagram</a>
                )}
                {lead.social.linkedin && (
                  <a href={lead.social.linkedin} target="_blank" rel="noopener" class="social-pill">LinkedIn</a>
                )}
              </div>
            )}
          </header>

          {lead.bio && <p class="lead-bio">{lead.bio}</p>}

          {lead.stats && lead.stats.length > 0 && (
            <div class="lead-stats">
              {lead.stats.map(s => (
                <div class="stat-cell">
                  <div class="stat-value">{s.value}</div>
                  <div class="stat-label">{s.label}</div>
                </div>
              ))}
            </div>
          )}

          {lead.tags && lead.tags.length > 0 && (
            <div class="lead-tags">
              {lead.tags.map(tag => <span class="member-tag">{tag}</span>)}
            </div>
          )}
        </div>
      </article>
    )}

    {members.length > 0 && (
      <div class="members-grid fade-up">
        {members.map(m => (
          <article class="member-card">
            <div class="member-head">
              <div class="member-avatar">
                {isImagePath(m.avatar) ? (
                  <img src={m.avatar} alt={m.name} loading="lazy" />
                ) : (
                  <span class="avatar-letter">{m.avatar}</span>
                )}
              </div>
              <div>
                <div class="member-name">{m.name}</div>
                <div class="member-role">{m.role}</div>
              </div>
            </div>

            {m.bio && <p class="member-bio">{m.bio}</p>}

            {m.tags && m.tags.length > 0 && (
              <div class="member-tags">
                {m.tags.map(tag => <span class="member-tag">{tag}</span>)}
              </div>
            )}
          </article>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  /* ─────────── Lead card (Магош) ─────────── */
  .lead-card {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 40px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 40px;
    margin-top: 48px;
    margin-bottom: 24px;
    position: relative;
    overflow: hidden;
  }
  .lead-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 4px;
    height: 100%;
    background: var(--gold);
    border-radius: var(--radius-lg) 0 0 var(--radius-lg);
  }

  .lead-avatar {
    width: 220px;
    height: 220px;
    background: var(--gold-dim);
    border: 2px solid var(--gold);
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    flex-shrink: 0;
  }
  .lead-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .lead-content {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .lead-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 20px;
    margin-bottom: 18px;
    flex-wrap: wrap;
  }
  .lead-name {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-bottom: 6px;
    color: var(--text);
    line-height: 1.15;
  }
  .lead-role {
    font-size: 0.92rem;
    color: var(--gold);
    font-weight: 500;
  }
  .lead-social {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .lead-bio {
    font-size: 0.96rem;
    color: var(--text-dim);
    line-height: 1.7;
    margin-bottom: 24px;
  }

  .lead-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    padding-top: 22px;
    border-top: 1px solid var(--border);
    margin-top: auto;
  }
  .stat-value {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--gold);
    line-height: 1;
    margin-bottom: 6px;
    letter-spacing: -0.02em;
  }
  .stat-label {
    font-size: 0.75rem;
    color: var(--text-dim);
    line-height: 1.35;
  }

  .lead-tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 20px;
  }

  /* ─────────── Members grid (3 равные карточки) ─────────── */
  .members-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 32px;
  }

  .member-card {
    display: flex;
    flex-direction: column;
    gap: 14px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 24px;
    transition: border-color 0.2s;
  }
  .member-card:hover {
    border-color: rgba(201, 168, 76, 0.2);
  }

  .member-head {
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .member-avatar {
    width: 56px;
    height: 56px;
    background: var(--surface);
    border: 1px solid var(--border-2);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    flex-shrink: 0;
  }
  .member-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .member-name {
    font-family: var(--font-body);
    font-size: 0.98rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1.25;
    margin-bottom: 2px;
  }
  .member-role {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--gold);
    letter-spacing: 0.04em;
  }

  .member-bio {
    font-size: 0.85rem;
    color: var(--text-dim);
    line-height: 1.6;
    margin: 0;
    flex-grow: 1;
  }

  .member-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-top: auto;
  }

  /* ─────────── Avatar letter (общий) ─────────── */
  .avatar-letter {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--gold);
  }
  .avatar-letter--lg {
    font-size: 4rem;
  }

  /* ─────────── Pills ─────────── */
  .social-pill {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    padding: 6px 12px;
    background: var(--surface);
    border: 1px solid var(--border-2);
    border-radius: var(--radius-sm);
    color: var(--text-dim);
    text-decoration: none;
    transition: color 0.2s, border-color 0.2s;
    letter-spacing: 0.04em;
  }
  .social-pill:hover {
    color: var(--gold);
    border-color: rgba(201, 168, 76, 0.3);
  }

  .member-tag {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    padding: 3px 8px;
    background: var(--surface);
    color: var(--text-dim);
    border-radius: 3px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  /* ─────────── Адаптив ─────────── */
  @media (max-width: 1024px) {
    .members-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 900px) {
    .lead-card {
      grid-template-columns: 1fr;
      padding: 32px 24px;
      gap: 24px;
    }
    .lead-avatar {
      width: 160px;
      height: 160px;
      margin: 0 auto;
    }
    .lead-header {
      justify-content: center;
      text-align: center;
    }
    .lead-stats {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 560px) {
    .members-grid {
      grid-template-columns: 1fr;
    }
    .lead-stats {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
