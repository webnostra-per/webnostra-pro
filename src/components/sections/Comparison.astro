---
/**
 * Comparison — двухколоночное сравнение WEBNOSTRA vs рынок.
 * Одинаковые метрики, контрастное выделение "нас" через золотую рамку.
 */

interface ComparisonRow {
  label: string;
  market: string;     // значение на рынке
  us: string;         // наше значение
}

interface Props {
  label?: string;
  title: string;
  subtitle?: string;
  rows: ComparisonRow[];
  marketHeading?: string;
  usHeading?: string;
}

const {
  label = 'Сравнение',
  title,
  subtitle,
  rows,
  marketHeading = 'Среднее по рынку',
  usHeading = 'WEBNOSTRA',
} = Astro.props;
---

<section class="comparison section">
  <div class="container">
    <div class="label">{label}</div>
    <h2 class="section-title fade-up" set:html={title} />
    {subtitle && <p class="section-subtitle">{subtitle}</p>}

    <div class="comparison-grid fade-up">
      <div class="comparison-col comparison-market">
        <div class="comparison-heading">{marketHeading}</div>
        <div class="comparison-rows">
          {rows.map(r => (
            <div class="comparison-row">
              <div class="comparison-row-label">{r.label}</div>
              <div class="comparison-row-value">{r.market}</div>
            </div>
          ))}
        </div>
      </div>

      <div class="comparison-col comparison-us">
        <div class="comparison-heading gold">{usHeading}</div>
        <div class="comparison-rows">
          {rows.map(r => (
            <div class="comparison-row">
              <div class="comparison-row-label">{r.label}</div>
              <div class="comparison-row-value gold">{r.us}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .comparison-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-top: 48px;
  }

  .comparison-col {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 32px;
  }
  .comparison-us {
    border-color: rgba(201, 168, 76, 0.3);
    background: linear-gradient(180deg, rgba(201, 168, 76, 0.04), var(--bg-card) 60%);
  }

  .comparison-heading {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 20px;
    font-weight: 500;
  }

  .comparison-rows { display: flex; flex-direction: column; gap: 16px; }
  .comparison-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--border);
  }
  .comparison-row:last-child { border-bottom: none; padding-bottom: 0; }
  .comparison-row-label {
    font-size: 0.88rem;
    color: var(--text-dim);
    flex: 1 1 auto;
    min-width: 0;
  }
  .comparison-row-value {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.02em;
    text-align: right;
    flex-shrink: 0;
    white-space: nowrap;
  }

  @media (max-width: 720px) {
    .comparison-grid { grid-template-columns: 1fr; }
    .comparison-col { padding: 24px 20px; }
    .comparison-row-value { font-size: 1.05rem; }
    .comparison-row-value.wrap { white-space: normal; }
  }
  @media (max-width: 380px) {
    .comparison-row-value { font-size: 0.95rem; }
  }
</style>
