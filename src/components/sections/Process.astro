---
/**
 * Process — процесс работы пошагово.
 * 4 шага в ряд с соединительной линией между ними.
 */

interface Step {
  title: string;
  description: string;
  duration: string;   // "2-3 дня"
}

interface Props {
  label?: string;
  title: string;
  subtitle?: string;
  steps: Step[];
}

const { label = 'Процесс', title, subtitle, steps } = Astro.props;
---

<section class="process section">
  <div class="container">
    <div class="label">{label}</div>
    <h2 class="section-title fade-up" set:html={title} />
    {subtitle && <p class="section-subtitle">{subtitle}</p>}

    <div class="process-grid fade-up">
      {steps.map((step, i) => (
        <div class="process-step">
          <div class="process-num">
            <span>{String(i + 1).padStart(2, '0')}</span>
          </div>
          <h3 class="process-title">{step.title}</h3>
          <p class="process-desc">{step.description}</p>
          <div class="process-duration">{step.duration}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .process-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-top: 48px;
    position: relative;
  }
  .process-grid::before {
    content: '';
    position: absolute;
    top: 32px;
    left: 10%;
    right: 10%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--border-2) 20%, var(--border-2) 80%, transparent);
    z-index: 0;
  }

  .process-step {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 0 12px;
  }

  .process-num {
    width: 64px; height: 64px;
    background: var(--bg-card);
    border: 2px solid var(--border-2);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--gold);
    margin: 0 auto 20px;
    transition: all 0.3s;
  }
  .process-step:hover .process-num {
    border-color: var(--gold);
    transform: scale(1.05);
  }

  .process-title {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 10px;
    color: var(--text);
  }
  .process-desc {
    font-size: 0.85rem;
    color: var(--text-dim);
    line-height: 1.6;
    margin-bottom: 12px;
  }
  .process-duration {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 500;
  }

  @media (max-width: 900px) {
    .process-grid { grid-template-columns: 1fr 1fr; }
    .process-grid::before { display: none; }
  }
  @media (max-width: 560px) {
    .process-grid { grid-template-columns: 1fr; gap: 32px; }
  }
</style>
