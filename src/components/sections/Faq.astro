---
/**
 * Faq — аккордеон FAQ с автоматической JSON-LD schema.org/FAQPage.
 * Фильтрует вопросы по тегам: tag='home' для главной, tag='thailand' для страницы Таиланда, и т.д.
 *
 * JSON-LD генерируется и возвращается в Astro.locals для встраивания в <head>
 * — но для простоты встраиваем через slot.
 *
 * Пропсы:
 *   tag — единый тег для фильтрации (напр. 'home', 'thailand', 'meta-ads')
 */

import { getCollection } from 'astro:content';
import { faqSchema } from '@lib/seo';

interface Props {
  label?: string;
  title: string;
  subtitle?: string;
  tag: string;
}

const { label = 'FAQ', title, subtitle, tag } = Astro.props;

const allFaq = (await getCollection('faq'))
  .map(f => f.data)
  .filter(f => f.tags.includes(tag as any))
  .sort((a, b) => a.order - b.order);

// Генерим JSON-LD для этой страницы
const schema = faqSchema(
  allFaq.map(f => ({ question: f.question, answer: f.answer }))
);
---

<section class="faq section">
  <div class="container">
    <div class="label">{label}</div>
    <h2 class="section-title fade-up" set:html={title} />
    {subtitle && <p class="section-subtitle">{subtitle}</p>}

    <div class="faq-list fade-up">
      {allFaq.map((f, i) => (
        <details class="faq-item" id={`faq-${f.id}`} open={i === 0}>
          <summary class="faq-q">
            <span>{f.question}</span>
            <span class="faq-arrow" aria-hidden="true">▾</span>
          </summary>
          <div class="faq-a">{f.answer}</div>
        </details>
      ))}
    </div>

    {allFaq.length === 0 && (
      <div class="faq-empty">FAQ по этой теме скоро появится.</div>
    )}
  </div>
</section>

<!-- JSON-LD FAQPage для SEO -->
<script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />

<style>
  .faq-list {
    margin-top: 48px;
    max-width: 820px;
  }
  .faq-item {
    border-bottom: 1px solid var(--border);
    padding: 4px 0;
  }
  .faq-q {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
    padding: 20px 0;
    cursor: pointer;
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    list-style: none;
    color: var(--text);
  }
  .faq-q::-webkit-details-marker { display: none; }
  .faq-arrow {
    color: var(--text-dim);
    transition: transform 0.3s, color 0.3s;
    flex-shrink: 0;
    font-size: 0.9em;
  }
  .faq-item[open] .faq-arrow {
    transform: rotate(180deg);
    color: var(--gold);
  }
  .faq-a {
    font-size: 0.92rem;
    color: var(--text-dim);
    line-height: 1.75;
    padding: 0 0 24px;
    max-width: 720px;
  }

  .faq-empty {
    margin-top: 48px;
    padding: 48px;
    text-align: center;
    color: var(--text-dim);
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }
</style>
