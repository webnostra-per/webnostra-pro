---
/**
 * Geography — сетка 6 стран недвижимости.
 * Флаг, название, языки как pills, переход на страницу страны.
 */

import { getCollection } from 'astro:content';

interface Props {
  label?: string;
  title: string;
  subtitle?: string;
}

const { label = 'География', title, subtitle } = Astro.props;

const geos = (await getCollection('geos'))
  .map(g => g.data)
  .sort((a, b) => a.order - b.order);
---

<section class="geography section">
  <div class="container">
    <div class="label">{label}</div>
    <h2 class="section-title fade-up" set:html={title} />
    {subtitle && <p class="section-subtitle">{subtitle}</p>}

    <div class="geo-grid">
      {geos.map(geo => (
        <a href={`/real-estate/${geo.id}/`} class={`geo-card fade-up ${geo.highlight ? 'geo-card-highlight' : ''}`}>
          <div class="geo-flag">{geo.flag}</div>
          <h3 class="geo-title">{geo.title}</h3>
          <p class="geo-desc">{geo.shortDescription}</p>
          <div class="geo-langs">
            {geo.languages.map(lang => (
              <span class="geo-lang">{lang}</span>
            ))}
          </div>
          {geo.casesCount > 0 && (
            <div class="geo-cases-count">{geo.casesCount} {geo.casesCount === 1 ? 'кейс' : 'кейсов'}</div>
          )}
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .geo-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 48px;
  }

  .geo-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 28px;
    text-decoration: none;
    color: inherit;
    transition: all 0.3s;
    position: relative;
  }
  .geo-card-highlight {
    border-color: rgba(201, 168, 76, 0.2);
    background: linear-gradient(180deg, rgba(201, 168, 76, 0.03), var(--bg-card) 60%);
  }
  .geo-card:hover {
    border-color: rgba(201, 168, 76, 0.3);
    transform: translateY(-3px);
  }

  .geo-flag {
    font-size: 2rem;
    margin-bottom: 14px;
    line-height: 1;
  }

  .geo-title {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-bottom: 8px;
    color: var(--text);
  }

  .geo-desc {
    font-size: 0.85rem;
    color: var(--text-dim);
    line-height: 1.6;
    margin-bottom: 16px;
  }

  .geo-langs {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 14px;
  }
  .geo-lang {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    padding: 3px 8px;
    background: var(--surface);
    color: var(--text-dim);
    border-radius: 3px;
    letter-spacing: 0.03em;
  }

  .geo-cases-count {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--gold);
    letter-spacing: 0.05em;
  }

  @media (max-width: 900px) {
    .geo-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 560px) {
    .geo-grid { grid-template-columns: 1fr; }
  }
</style>
