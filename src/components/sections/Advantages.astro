---
/**
 * Advantages — 6 карточек с пронумерованными преимуществами.
 * Номер крупный золотой, заголовок, текст.
 */

interface Advantage {
  title: string;
  description: string;
}

interface Props {
  label?: string;
  title: string;
  subtitle?: string;
  items: Advantage[];
}

const { label = 'Преимущества', title, subtitle, items } = Astro.props;
---

<section class="advantages section">
  <div class="container">
    <div class="label">{label}</div>
    <h2 class="section-title fade-up" set:html={title} />
    {subtitle && <p class="section-subtitle">{subtitle}</p>}

    <div class="adv-grid">
      {items.map((a, i) => (
        <div class="adv-card fade-up">
          <div class="adv-num">{String(i + 1).padStart(2, '0')}</div>
          <h3 class="adv-title">{a.title}</h3>
          <p class="adv-desc">{a.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .adv-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 48px;
  }

  .adv-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 32px 28px;
    transition: all 0.3s;
  }
  .adv-card:hover {
    border-color: rgba(201, 168, 76, 0.2);
    transform: translateY(-3px);
  }

  .adv-num {
    font-family: var(--font-display);
    font-size: 1.8rem;
    font-weight: 700;
    color: rgba(201, 168, 76, 0.25);
    margin-bottom: 12px;
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .adv-title {
    font-family: var(--font-body);
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 12px;
    color: var(--text);
    letter-spacing: 0;
  }

  .adv-desc {
    font-size: 0.9rem;
    color: var(--text-dim);
    line-height: 1.65;
  }

  @media (max-width: 900px) {
    .adv-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 560px) {
    .adv-grid { grid-template-columns: 1fr; }
  }
</style>
