---
/**
 * CasesGrid — сетка карточек кейсов.
 * Поддерживает фильтрацию по industry / channels / geoSlug через пропсы.
 *
 * Пропсы:
 *   industry — фильтр по отрасли
 *   channel — фильтр по каналу (один)
 *   geoSlug — фильтр по стране
 *   excludeFeatured — скрыть featured-кейсы (они уже показаны в CasesFeatured)
 *   limit — ограничить количество
 */

import { getCollection, type CollectionEntry } from 'astro:content';

interface Props {
  label?: string;
  title: string;
  subtitle?: string;
  industry?: string;
  channel?: string;
  geoSlug?: string;
  excludeFeatured?: boolean;
  limit?: number;
}

const {
  label,
  title,
  subtitle,
  industry,
  channel,
  geoSlug,
  excludeFeatured = false,
  limit,
} = Astro.props;

let cases: CollectionEntry<'cases'>[] = await getCollection('cases', (entry) => entry.data.published !== false);

if (industry) cases = cases.filter(c => c.data.industry === industry);
if (channel) cases = cases.filter(c => c.data.channels.includes(channel as any));
if (geoSlug) cases = cases.filter(c => c.data.geoSlug === geoSlug);
if (excludeFeatured) cases = cases.filter(c => !c.data.featured);

cases = cases.sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
if (limit) cases = cases.slice(0, limit);
---

<section class="cases-grid-section section">
  <div class="container">
    {label && <div class="label">{label}</div>}
    {title && <h2 class="section-title fade-up" set:html={title} />}
    {subtitle && <p class="section-subtitle">{subtitle}</p>}

    <div class="cases-grid">
      {cases.map(c => (
        <a href={`/portfolio/${c.data.slug || c.id}/`} class="case-card fade-up">
          <div class="case-card-tags">
            {c.data.channels.slice(0, 2).map(ch => (
              <span class="case-tag-sm">{ch.replace('-', ' ')}</span>
            ))}
            <span class="case-tag-sm case-tag-dim">{c.data.geo.split(',')[0]}</span>
          </div>

          <div class="case-card-period">{c.data.period}</div>

          <h3 class="case-card-title">{c.data.title}</h3>

          <p class="case-card-desc">{c.data.shortDescription}</p>

          <div class="case-card-headline">
            <div class="case-card-headline-val">{c.data.headlineValue}</div>
            <div class="case-card-headline-label">{c.data.headlineLabel}</div>
          </div>

          <div class="case-card-metrics">
            {c.data.metrics.slice(0, 4).map(m => (
              <div class="case-card-metric">
                <div class={`case-card-metric-val ${m.highlight ? 'gold' : ''}`}>{m.value}</div>
                <div class="case-card-metric-label">{m.label}</div>
              </div>
            ))}
          </div>
        </a>
      ))}
    </div>

    {cases.length === 0 && (
      <div class="cases-empty">
        Кейсы по этому фильтру скоро появятся. <a href="/portfolio/">Смотреть все кейсы →</a>
      </div>
    )}
  </div>
</section>

<style>
  .cases-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 48px;
  }

  .case-card {
    display: flex;
    flex-direction: column;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 24px;
    text-decoration: none;
    color: inherit;
    transition: all 0.25s;
  }
  .case-card:hover {
    border-color: rgba(201, 168, 76, 0.2);
    transform: translateY(-2px);
  }

  .case-card-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 12px;
  }
  .case-tag-sm {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    padding: 3px 8px;
    background: var(--gold-dim);
    color: var(--gold);
    border-radius: 3px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-weight: 500;
  }
  .case-tag-dim { background: var(--surface); color: var(--text-dim); }

  .case-card-period {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--text-muted);
    margin-bottom: 12px;
  }

  .case-card-title {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 10px;
    color: var(--text);
    letter-spacing: 0;
  }

  .case-card-desc {
    font-size: 0.83rem;
    color: var(--text-dim);
    line-height: 1.55;
    margin-bottom: 20px;
  }

  .case-card-headline {
    padding: 14px 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    margin-bottom: 16px;
  }
  .case-card-headline-val {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--gold);
    line-height: 1;
    margin-bottom: 4px;
    letter-spacing: -0.02em;
  }
  .case-card-headline-label {
    font-size: 0.72rem;
    color: var(--text-dim);
  }

  .case-card-metrics {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 8px 14px;
  }
  .case-card-metric-val {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1;
    margin-bottom: 2px;
  }
  .case-card-metric-val.gold { color: var(--gold); }
  .case-card-metric-label {
    font-size: 0.68rem;
    color: var(--text-muted);
  }

  .cases-empty {
    padding: 48px;
    text-align: center;
    color: var(--text-dim);
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    margin-top: 48px;
  }
  .cases-empty a { color: var(--gold); text-decoration: none; }

  @media (max-width: 900px) {
    .cases-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 560px) {
    .cases-grid { grid-template-columns: 1fr; }
  }
</style>
