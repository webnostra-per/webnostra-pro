---
/**
 * CasesGrid - сетка карточек кейсов.
 * Поддерживает фильтрацию по industry / channels / geoSlug через пропсы.
 *
 * Пропсы:
 *   industry - фильтр по отрасли
 *   channel - фильтр по каналу (один)
 *   geoSlug - фильтр по стране
 *   excludeFeatured - скрыть featured-кейсы (они уже показаны в CasesFeatured)
 *   limit - ограничить количество
 */

import { getCollection, type CollectionEntry } from 'astro:content';

interface Props {
  label?: string;
  title: string;
  subtitle?: string;
  industry?: string;
  channel?: string;
  geoSlug?: string;
  excludeFeatured?: boolean;
  excludeSlug?: string;  // исключить конкретный кейс по slug или id - чтобы на странице кейса не показывать его же
  limit?: number;
  showFilters?: boolean;  // v2.23: интерактивный рубрикатор по industry
}

const {
  label,
  title,
  subtitle,
  industry,
  channel,
  geoSlug,
  excludeFeatured = false,
  excludeSlug,
  limit,
  showFilters = false,
} = Astro.props;

let cases: CollectionEntry<'cases'>[] = await getCollection('cases', (entry) => entry.data.published !== false);

if (industry) cases = cases.filter(c => c.data.industry === industry);
if (channel) cases = cases.filter(c => c.data.channels.includes(channel as any));
if (geoSlug) cases = cases.filter(c => c.data.geoSlug === geoSlug);
if (excludeFeatured) cases = cases.filter(c => !c.data.featured);
if (excludeSlug) cases = cases.filter(c => (c.data.slug || c.id) !== excludeSlug);

cases = cases.sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
if (limit) cases = cases.slice(0, limit);

// v2.23: агрегация industries для рубрикатора. Только если showFilters=true.
const INDUSTRY_LABELS: Record<string, string> = {
  'real-estate': 'Недвижимость',
  'e-commerce': 'E-commerce',
  'edtech': 'Инфобизнес',
  'tourism': 'Туризм',
  'medical': 'Медицина',
  'b2b': 'B2B',
  'kids': 'Детские услуги',
  'auto': 'Авто',
  'fitness': 'Фитнес',
  'franchise': 'Франшизы',
  'legal': 'Юридические',
  'other': 'Другое',
};

const industryCounts = new Map<string, number>();
if (showFilters) {
  for (const c of cases) {
    const i = c.data.industry;
    industryCounts.set(i, (industryCounts.get(i) || 0) + 1);
  }
}
const industriesList = Array.from(industryCounts.entries())
  .sort((a, b) => b[1] - a[1])
  .map(([id, count]) => ({ id, label: INDUSTRY_LABELS[id] || id, count }));
---

<section class="cases-grid-section section">
  <div class="container">
    {label && <div class="label">{label}</div>}
    {title && <h2 class="section-title fade-up" set:html={title} />}
    {subtitle && <p class="section-subtitle">{subtitle}</p>}

    {showFilters && industriesList.length > 1 && (
      <div class="cases-filters fade-up" role="tablist" aria-label="Фильтр кейсов по нише">
        <button class="cases-filter-tab active" data-filter="all" role="tab" aria-selected="true">
          Все <span class="cases-filter-count">{cases.length}</span>
        </button>
        {industriesList.map(i => (
          <button class="cases-filter-tab" data-filter={i.id} role="tab" aria-selected="false">
            {i.label} <span class="cases-filter-count">{i.count}</span>
          </button>
        ))}
      </div>
    )}

    <div class="cases-grid">
      {cases.map(c => (
        <a href={`/portfolio/${c.data.slug || c.id}/`} class="case-card fade-up" data-industry={c.data.industry}>
          <div class="case-card-tags">
            {c.data.channels.slice(0, 2).map(ch => (
              <span class="case-tag-sm">{ch.replace('-', ' ')}</span>
            ))}
            <span class="case-tag-sm case-tag-dim">{c.data.geo.split(',')[0]}</span>
          </div>

          <div class="case-card-period">{c.data.period}</div>

          <h3 class="case-card-title">{c.data.title}</h3>

          <p class="case-card-desc">{c.data.shortDescription}</p>

          <div class="case-card-headline">
            <div class="case-card-headline-val">{c.data.headlineValue}</div>
            <div class="case-card-headline-label">{c.data.headlineLabel}</div>
          </div>

          <div class="case-card-metrics">
            {c.data.metrics.slice(0, 4).map(m => (
              <div class="case-card-metric">
                <div class={`case-card-metric-val ${m.highlight ? 'gold' : ''}`}>{m.value}</div>
                <div class="case-card-metric-label">{m.label}</div>
              </div>
            ))}
          </div>
        </a>
      ))}
    </div>

    {cases.length === 0 && (
      <div class="cases-empty">
        Кейсы по этому фильтру скоро появятся. <a href="/portfolio/">Смотреть все кейсы →</a>
      </div>
    )}

    {showFilters && (
      <div class="cases-empty-filter" data-empty-state hidden>
        Нет кейсов в этой категории. <button type="button" data-reset-filter>Показать все</button>
      </div>
    )}
  </div>
</section>

{showFilters && (
  <script>
    (function() {
      const tabs = document.querySelectorAll('.cases-filter-tab');
      const cards = document.querySelectorAll('.cases-grid .case-card');
      const emptyState = document.querySelector('[data-empty-state]') as HTMLElement | null;
      const resetBtn = document.querySelector('[data-reset-filter]') as HTMLButtonElement | null;

      // Список валидных фильтров (id ниш, которые реально есть в сетке)
      const validFilters = new Set<string>();
      tabs.forEach(t => {
        const f = (t as HTMLElement).dataset.filter;
        if (f) validFilters.add(f);
      });

      function applyFilter(filter: string, updateUrl: boolean = true) {
        // Если фильтр невалидный (битая ссылка) — показываем все
        if (!validFilters.has(filter)) filter = 'all';

        let visibleCount = 0;
        cards.forEach(card => {
          const industry = (card as HTMLElement).dataset.industry || '';
          const show = filter === 'all' || industry === filter;
          (card as HTMLElement).style.display = show ? '' : 'none';
          if (show) visibleCount++;
        });

        tabs.forEach(t => {
          const active = (t as HTMLElement).dataset.filter === filter;
          t.classList.toggle('active', active);
          t.setAttribute('aria-selected', active ? 'true' : 'false');
        });

        if (emptyState) emptyState.hidden = visibleCount > 0;

        // Обновление URL hash без скролла и без записи в историю
        if (updateUrl) {
          const newHash = filter === 'all' ? '' : `#${filter}`;
          const newUrl = window.location.pathname + window.location.search + newHash;
          history.replaceState(null, '', newUrl);
        }
      }

      // Инициализация: читаем hash при загрузке страницы
      function getFilterFromHash(): string {
        const hash = window.location.hash.slice(1);
        return hash || 'all';
      }

      const initialFilter = getFilterFromHash();
      if (initialFilter !== 'all') {
        // Применяем без обновления URL — hash уже там
        applyFilter(initialFilter, false);
      }

      // Клики по табам
      tabs.forEach(tab => {
        tab.addEventListener('click', () => {
          const filter = (tab as HTMLElement).dataset.filter || 'all';
          applyFilter(filter);
        });
      });

      if (resetBtn) {
        resetBtn.addEventListener('click', () => applyFilter('all'));
      }

      // Реакция на изменение hash (если пользователь меняет URL вручную
      // или переходит по якорной ссылке внутри страницы)
      window.addEventListener('hashchange', () => {
        applyFilter(getFilterFromHash(), false);
      });
    })();
  </script>
)}

<style>
  /* v2.23: Рубрикатор (таб-фильтр) */
  .cases-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 32px;
    padding-bottom: 4px;
  }

  .cases-filter-tab {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 9px 16px;
    font-family: var(--font-body);
    font-size: 0.88rem;
    color: var(--text-dim);
    cursor: pointer;
    transition: all 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .cases-filter-tab:hover {
    border-color: rgba(201, 168, 76, 0.3);
    color: var(--text);
  }

  .cases-filter-tab.active {
    background: var(--gold-dim);
    border-color: var(--gold);
    color: var(--gold);
    font-weight: 600;
  }

  .cases-filter-count {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    padding: 2px 7px;
    background: var(--surface);
    border-radius: 999px;
    color: var(--text-muted);
    font-weight: 500;
  }

  .cases-filter-tab.active .cases-filter-count {
    background: rgba(201, 168, 76, 0.25);
    color: var(--gold);
  }

  .cases-empty-filter {
    padding: 32px;
    text-align: center;
    color: var(--text-dim);
    background: var(--bg-card);
    border: 1px dashed var(--border);
    border-radius: var(--radius);
    margin-top: 24px;
    font-size: 0.95rem;
  }

  .cases-empty-filter button {
    background: none;
    border: none;
    color: var(--gold);
    cursor: pointer;
    font-family: inherit;
    font-size: inherit;
    text-decoration: underline;
    padding: 0;
    margin-left: 4px;
  }

  .cases-filters + .cases-grid {
    margin-top: 24px;
  }

  .cases-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 48px;
  }

  .case-card {
    display: flex;
    flex-direction: column;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 24px;
    text-decoration: none;
    color: inherit;
    transition: all 0.25s;
  }
  .case-card:hover {
    border-color: rgba(201, 168, 76, 0.2);
    transform: translateY(-2px);
  }

  .case-card-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 12px;
  }
  .case-tag-sm {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    padding: 3px 8px;
    background: var(--gold-dim);
    color: var(--gold);
    border-radius: 3px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-weight: 500;
  }
  .case-tag-dim { background: var(--surface); color: var(--text-dim); }

  .case-card-period {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--text-muted);
    margin-bottom: 12px;
  }

  .case-card-title {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 10px;
    color: var(--text);
    letter-spacing: 0;
  }

  .case-card-desc {
    font-size: 0.83rem;
    color: var(--text-dim);
    line-height: 1.55;
    margin-bottom: 20px;
  }

  .case-card-headline {
    padding: 14px 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    margin-bottom: 16px;
  }
  .case-card-headline-val {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--gold);
    line-height: 1;
    margin-bottom: 4px;
    letter-spacing: -0.02em;
  }
  .case-card-headline-label {
    font-size: 0.72rem;
    color: var(--text-dim);
  }

  .case-card-metrics {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 8px 14px;
  }
  .case-card-metric-val {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1;
    margin-bottom: 2px;
  }
  .case-card-metric-val.gold { color: var(--gold); }
  .case-card-metric-label {
    font-size: 0.68rem;
    color: var(--text-muted);
  }

  .cases-empty {
    padding: 48px;
    text-align: center;
    color: var(--text-dim);
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    margin-top: 48px;
  }
  .cases-empty a { color: var(--gold); text-decoration: none; }

  @media (max-width: 900px) {
    .cases-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 560px) {
    .cases-grid { grid-template-columns: 1fr; }
  }
</style>
